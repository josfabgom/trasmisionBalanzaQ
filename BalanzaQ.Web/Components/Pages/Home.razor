@page "/"
@rendermode InteractiveServer
@using BalanzaQ.Web.Models
@using BalanzaQ.Web.Data
@using BalanzaQ.Web.Services
@using Microsoft.EntityFrameworkCore
@inject BalanzaDbContext DbContext
@inject ImportService ImportService
@inject DigiService DigiService
@inject BrandingService BrandingService
@inject IJSRuntime JS

<PageTitle>BalanzaQ - Dashboard</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card border-0 shadow-sm overflow-hidden" style="border-radius: 15px; background: linear-gradient(135deg, #ffffff 0%, #f1f4f9 100%);">
                <div class="card-body p-0">
                    <div class="row g-0 align-items-center">
                        <div class="col-md-auto p-4 text-center" style="background: rgba(13, 110, 253, 0.03); min-width: 200px;">
                            @if (!string.IsNullOrEmpty(BrandingService.BusinessLogoBase64))
                            {
                                <img src="data:image/png;base64,@BrandingService.BusinessLogoBase64" class="img-fluid animate__animated animate__fadeIn" style="max-height: 100px; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1));" alt="Logo" />
                            }
                            else
                            {
                                <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center shadow" style="width: 80px; height: 80px;">
                                    <i class="bi bi-shop display-6"></i>
                                </div>
                            }
                        </div>
                        <div class="col-md p-4">
                            <h1 class="display-5 fw-bold text-primary mb-1">@BrandingService.BusinessName</h1>
                            <p class="text-muted mb-3 fw-medium">Sistema de Transmisión Multi-Balanza Digi SM-300</p>
                            
                            <div class="d-flex flex-wrap gap-3 mt-2">
                                @if (!string.IsNullOrEmpty(BrandingService.BusinessAddress))
                                {
                                    <span class="badge bg-white text-dark border shadow-sm px-3 py-2 rounded-pill">
                                        <i class="bi bi-geo-alt-fill text-primary me-2"></i> @BrandingService.BusinessAddress
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(BrandingService.BusinessPhone))
                                {
                                    <span class="badge bg-white text-dark border shadow-sm px-3 py-2 rounded-pill">
                                        <i class="bi bi-telephone-fill text-success me-2"></i> @BrandingService.BusinessPhone
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(BrandingService.BusinessEmail))
                                {
                                    <span class="badge bg-white text-dark border shadow-sm px-3 py-2 rounded-pill">
                                        <i class="bi bi-envelope-at-fill text-info me-2"></i> @BrandingService.BusinessEmail
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Mensaje))
    {
        <div class="alert @ClaseAlerta alert-dismissible fade show" role="alert">
            @Mensaje
            <button type="button" class="btn-close" @onclick="() => Mensaje = null"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h2 class="h1 mb-3">📦 @_totalArticulos</h2>
                    <h5 class="card-title text-muted">Artículos Importados</h5>
                    <label for="fileInput" class="btn btn-primary btn-lg mt-3 w-100 @(_isImporting ? "disabled" : "")">
                        @if (_isImporting)
                        {
                            <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                            <span> Importando...</span>
                        }
                        else
                        {
                            <span><i class="bi bi-cloud-download"></i> Seleccionar Módulo (.dat)</span>
                        }
                    </label>
                    <InputFile id="fileInput" OnChange="ImportarDatos" accept=".dat,.txt,.csv" style="display: none;" disabled="@_isImporting" />
                    <button class="btn btn-warning w-100 mt-2" @onclick="SincronizarLocal" disabled="@_isImporting">
                        <i class="bi bi-arrow-repeat"></i> Sincronizar data.dat Local
                    </button>
                    <a href="/articulos" class="btn btn-outline-secondary w-100 mt-2">Gestionar Artículos</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-6">
            <div class="card h-100 shadow-sm border-primary">
                <div class="card-body text-center text-primary">
                    <h2 class="h1 mb-3">📡 @_balanzasActivas / @_totalBalanzas</h2>
                    <h5 class="card-title text-muted">Balanzas Activas</h5>
                    
                    <button class="btn btn-success btn-lg mt-3 w-100" @onclick="() => SincronizarTodas(true)" disabled="@_isSyncing">
                        @if (_isSyncing)
                        {
                            <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                            <span> Transmitiendo...</span>
                        }
                        else
                        {
                            <span><i class="bi bi-broadcast"></i> Generar y Enviar a Balanzas</span>
                        }
                    </button>
                    
                    <div class="d-flex mt-2 gap-2">
                        <button class="btn btn-outline-primary w-100" @onclick="() => SincronizarTodas(false)" disabled="@_isSyncing">
                            <i class="bi bi-file-earmark-code"></i> Solo Generar Archivos DAT
                        </button>
                        <a href="/balanzas" class="btn btn-outline-primary w-100">Configuración</a>
                    </div>

                    @if (_isSyncing)
                    {
                        <div class="mt-4 p-3 border rounded bg-light shadow-sm animate__animated animate__fadeIn">
                            <div class="d-flex justify-content-between mb-1">
                                <small class="text-muted fw-bold">@_statusMessage</small>
                                <small class="text-primary fw-bold">@_progressPercent%</small>
                            </div>
                            <div class="progress" style="height: 12px; border-radius: 6px; overflow: hidden;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated bg-gradient" 
                                     role="progressbar" 
                                     style="width: @_progressPercent%; background: linear-gradient(90deg, #0d6efd, #0dcaf0);" 
                                     aria-valuenow="@_progressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <div class="text-center mt-2">
                                <small class="text-muted">Procesando @_currentStep de @_totalSteps etapas...</small>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int _totalArticulos = 0;
    private int _totalBalanzas = 0;
    private int _balanzasActivas = 0;
    
    private bool _isImporting = false;
    private bool _isSyncing = false;
    
    private string? _statusMessage;
    private int _progressPercent = 0;
    private int _currentStep = 0;
    private int _totalSteps = 0;

    private string? Mensaje;
    private string ClaseAlerta = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        await CargarEstadisticas();
    }

    private async Task CargarEstadisticas()
    {
        _totalArticulos = await DbContext.PluItems.CountAsync();
        _totalBalanzas = await DbContext.Balanzas.CountAsync();
        _balanzasActivas = await DbContext.Balanzas.CountAsync(b => b.IsEnabled);
    }

    private async Task ImportarDatos(InputFileChangeEventArgs e)
    {
        _isImporting = true;
        try
        {
            var allowedSize = 10 * 1024 * 1024; // max 10MB para data.dat
            using var stream = e.File.OpenReadStream(allowedSize);
            int importados = await ImportService.ImportarDatosAsync(stream, null, e.File.Name);
            Mensaje = $"Importación exitosa. Se procesaron/actualizaron {importados} artículos del archivo {e.File.Name}.";
            ClaseAlerta = "alert-success";
            await CargarEstadisticas();
        }
        catch(Exception ex)
        {
            Mensaje = $"Error al importar: {ex.Message}";
            ClaseAlerta = "alert-danger";
        }
        finally
        {
            _isImporting = false;
        }
    }

    private async Task SincronizarLocal()
    {
        _isImporting = true;
        try
        {
            string path = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "..", "data.dat");
            // Fallback for portable mode
            if (!File.Exists(path)) path = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "data.dat");
            
            if (File.Exists(path))
            {
                using var fs = new FileStream(path, FileMode.Open, FileAccess.Read);
                int importados = await ImportService.ImportarDatosAsync(fs, null, "data.dat (Sync Local)");
                Mensaje = $"Sincronización local exitosa. Se actualizaron {importados} artículos desde el archivo data.dat de la raíz.";
                ClaseAlerta = "alert-success";
                await CargarEstadisticas();
            }
            else
            {
                Mensaje = "No se encontró el archivo data.dat en la carpeta raíz para sincronización directa.";
                ClaseAlerta = "alert-warning";
            }
        }
        catch (Exception ex)
        {
            Mensaje = $"Error en sincronización local: {ex.Message}";
            ClaseAlerta = "alert-danger";
        }
        finally
        {
            _isImporting = false;
        }
    }

    private async Task SincronizarTodas(bool enviarABalanza)
    {
        _isSyncing = true;
        _progressPercent = 0;
        _currentStep = 0;
        
        try
        {
            var balanzas = await DbContext.Balanzas.Where(b => b.IsEnabled).ToListAsync();
            var articulos = await DbContext.PluItems.ToListAsync();

            if (!balanzas.Any())
            {
                Mensaje = "No hay balanzas activas configuradas.";
                ClaseAlerta = "alert-warning";
                return;
            }

            // Calculo aproximado de pasos totales (balanzas * lotes de 1000)
            int batchSize = 1000;
            int batchesPerBalanza = (int)Math.Ceiling((double)articulos.Count / batchSize);
            if (batchesPerBalanza == 0) batchesPerBalanza = 1;
            _totalSteps = balanzas.Count * batchesPerBalanza;

            int exitos = 0;
            string batchId = Guid.NewGuid().ToString().Substring(0, 8).ToUpper();

            for (int bIdx = 0; bIdx < balanzas.Count; bIdx++)
            {
                var b = balanzas[bIdx];
                _statusMessage = $"Sincronizando {b.IpAddress}...";
                StateHasChanged();

                var res = await DigiService.SyncBalanzaAsync(b, articulos, enviarABalanza, (current, total) => {
                    // Este callback se llama en cada lote
                    _currentStep++;
                    _progressPercent = (int)((double)_currentStep / _totalSteps * 100);
                    _statusMessage = $"Balanza {b.IpAddress}: {current}/{total} PLUs";
                    StateHasChanged();
                }, batchId);

                b.LastSyncDate = DateTime.Now;
                b.LastSyncStatus = res.Message;
                
                if(res.Message.Contains("Exito") || res.Message.Contains("Generado"))
                {
                    exitos++;
                    if (!enviarABalanza && !string.IsNullOrEmpty(res.HexPayload))
                    {
                        string fileName = $"SM{b.IpAddress}F37.DAT";
                        await JS.InvokeVoidAsync("downloadTextFile", fileName, res.HexPayload);
                    }
                }
            }
            await DbContext.SaveChangesAsync();

            Mensaje = enviarABalanza ? $"Transmisión completada. {exitos} de {balanzas.Count} exitosas." : $"Módulos locales descargados para {balanzas.Count} balanzas.";
            ClaseAlerta = exitos == balanzas.Count ? "alert-success" : "alert-warning";
        }
        catch(Exception ex)
        {
            Mensaje = $"Error crítico en transmisión: {ex.Message}";
            ClaseAlerta = "alert-danger";
        }
        finally
        {
            _isSyncing = false;
        }
    }
}
