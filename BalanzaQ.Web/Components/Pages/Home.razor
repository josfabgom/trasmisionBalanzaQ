@page "/"
@rendermode InteractiveServer
@using BalanzaQ.Web.Models
@using BalanzaQ.Web.Data
@using BalanzaQ.Web.Services
@using Microsoft.EntityFrameworkCore
@inject BalanzaDbContext DbContext
@inject ImportService ImportService
@inject DigiService DigiService
@inject BrandingService BrandingService
@inject IJSRuntime JS

<PageTitle>BalanzaQ - Dashboard</PageTitle>

<div class="header-premium d-flex justify-content-between align-items-center anim-fade-in shadow-sm">
    <div class="d-flex align-items-center">
        <div class="icon-box-md bg-primary-soft text-primary me-4 shadow-sm">
             @if (!string.IsNullOrEmpty(BrandingService.BusinessLogoBase64)) {
                <img src="data:image/png;base64,@BrandingService.BusinessLogoBase64" class="img-fluid" style="max-height: 38px;" alt="Logo" />
             } else {
                <i class="bi bi-shop fs-3"></i>
             }
        </div>
        <div>
            <h1 class="h3 mb-1 fw-bold text-dark">@BrandingService.BusinessName</h1>
            <p class="text-muted small mb-0"><i class="bi bi-check2-all text-success me-1"></i> Sistema de Gestión y Transmisión de Balanzas Digi</p>
        </div>
    </div>
    <div class="text-end d-none d-md-block">
        <div class="text-uppercase xsmall text-muted fw-bold mb-1">Estado del Sistema</div>
        <span class="badge bg-success-soft text-success px-3 py-2 rounded-pill border border-success border-opacity-10">
            <i class="bi bi-patch-check-fill me-1"></i> Operativo
        </span>
    </div>
</div>

@if (!string.IsNullOrEmpty(Mensaje))
{
    <div class="alert @ClaseAlerta alert-dismissible fade show shadow-sm border-0 anim-fade-in mb-4" role="alert">
        <i class="bi bi-info-circle-fill me-2"></i> @Mensaje
        <button type="button" class="btn-close" @onclick="() => Mensaje = null"></button>
    </div>
}

<div class="row g-4 anim-fade-in" style="animation-delay: 0.1s;">
    <!-- CARD: GESTION DE ARCHIVOS -->
    <div class="col-xl-6">
        <div class="card card-premium h-100 p-2">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <h5 class="fw-bold mb-1">Módulo de Datos</h5>
                        <p class="text-muted small">Importación y sincronización de artículos.</p>
                    </div>
                    <div class="display-6 fw-bold text-primary opacity-25">📦</div>
                </div>

                <div class="text-center py-4 bg-light rounded-4 mb-4">
                    <div class="display-4 fw-bold text-dark mb-0">@_totalArticulos</div>
                    <div class="text-muted xsmall text-uppercase fw-bold">Productos en Memoria</div>
                </div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <label for="fileInput" class="btn btn-primary w-100 py-2 @(_isImporting ? "disabled" : "")">
                            @if (_isImporting) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            else { <i class="bi bi-cloud-arrow-up me-2"></i> }
                            Importar Módulo
                        </label>
                        <InputFile id="fileInput" OnChange="ImportarDatos" accept=".dat,.txt,.csv" style="display: none;" disabled="@_isImporting" />
                    </div>
                    <div class="col-md-6">
                        <button class="btn btn-outline-primary w-100 py-2" @onclick="SincronizarLocal" disabled="@_isImporting">
                            <i class="bi bi-arrow-repeat me-2"></i> Sync data.dat
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- CARD: TRANSMISION -->
    <div class="col-xl-6">
        <div class="card card-premium h-100 p-2 border-start border-primary border-4" style="border-left: 4px solid #0d6efd !important;">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <h5 class="fw-bold mb-1">Estado de Transmisión</h5>
                        <p class="text-muted small">Estado actual de las balanzas configuradas.</p>
                    </div>
                    <div class="display-6 fw-bold text-primary opacity-25">📡</div>
                </div>

                <div class="text-center py-4 bg-primary-soft rounded-4 mb-4">
                    <div class="display-4 fw-bold text-primary mb-0">@_balanzasActivas / @_totalBalanzas</div>
                    <div class="text-muted xsmall text-uppercase fw-bold">Equipos Activos</div>
                </div>

                <div class="btn-group w-100 shadow-sm">
                    <button class="btn btn-primary py-2 px-4 flex-grow-1" @onclick="() => SincronizarTodas(true)" disabled="@_isSyncing">
                        @if (_isSyncing) { <span class="spinner-border spinner-border-sm me-2"></span><span>Procesando...</span> }
                        else { <i class="bi bi-broadcast me-2"></i><span>Enviar a Balanzas</span> }
                    </button>
                    <button class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false" disabled="@_isSyncing">
                        <span class="visually-hidden">Opciones</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                        <li><button class="dropdown-item py-2" @onclick="() => SincronizarTodas(false)">
                            <i class="bi bi-file-earmark-code me-2 text-primary"></i>Descargar Archivos DAT
                        </button></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item py-2" href="/balanzas">
                            <i class="bi bi-gear me-2 text-muted"></i>Configurar Equipos
                        </a></li>
                    </ul>
                </div>

                @if (_isSyncing)
                {
                    <div class="mt-4 p-3 bg-light rounded-4 shadow-sm anim-fade-in border">
                        <div class="d-flex justify-content-between mb-2">
                            <small class="text-dark fw-bold xsmall">@_statusMessage</small>
                            <small class="text-primary fw-bold xsmall">@_progressPercent%</small>
                        </div>
                        <div class="progress" style="height: 8px; border-radius: 4px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" 
                                 role="progressbar" 
                                 style="width: @_progressPercent%;" 
                                 aria-valuenow="@_progressPercent" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                        <div class="text-center mt-2">
                            <small class="text-muted xsmall">Transmitiendo datos, por favor espere...</small>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private int _totalArticulos = 0;
    private int _totalBalanzas = 0;
    private int _balanzasActivas = 0;
    
    private bool _isImporting = false;
    private bool _isSyncing = false;
    
    private string? _statusMessage;
    private int _progressPercent = 0;
    private int _currentStep = 0;
    private int _totalSteps = 0;

    private string? Mensaje;
    private string ClaseAlerta = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        await CargarEstadisticas();
    }

    private async Task CargarEstadisticas()
    {
        _totalArticulos = await DbContext.PluItems.CountAsync();
        _totalBalanzas = await DbContext.Balanzas.CountAsync();
        _balanzasActivas = await DbContext.Balanzas.CountAsync(b => b.IsEnabled);
    }

    private async Task ImportarDatos(InputFileChangeEventArgs e)
    {
        _isImporting = true;
        try
        {
            var allowedSize = 10 * 1024 * 1024; // max 10MB para data.dat
            using var stream = e.File.OpenReadStream(allowedSize);
            int importados = await ImportService.ImportarDatosAsync(stream, null, e.File.Name);
            Mensaje = $"Importación exitosa. Se procesaron/actualizaron {importados} artículos del archivo {e.File.Name}.";
            ClaseAlerta = "alert-success";
            await CargarEstadisticas();
        }
        catch(Exception ex)
        {
            Mensaje = $"Error al importar: {ex.Message}";
            ClaseAlerta = "alert-danger";
        }
        finally
        {
            _isImporting = false;
        }
    }

    private async Task SincronizarLocal()
    {
        _isImporting = true;
        try
        {
            string path = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "..", "data.dat");
            // Fallback for portable mode
            if (!File.Exists(path)) path = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "data.dat");
            
            if (File.Exists(path))
            {
                using var fs = new FileStream(path, FileMode.Open, FileAccess.Read);
                int importados = await ImportService.ImportarDatosAsync(fs, null, "data.dat (Sync Local)");
                Mensaje = $"Sincronización local exitosa. Se actualizaron {importados} artículos desde el archivo data.dat de la raíz.";
                ClaseAlerta = "alert-success";
                await CargarEstadisticas();
            }
            else
            {
                Mensaje = "No se encontró el archivo data.dat en la carpeta raíz para sincronización directa.";
                ClaseAlerta = "alert-warning";
            }
        }
        catch (Exception ex)
        {
            Mensaje = $"Error en sincronización local: {ex.Message}";
            ClaseAlerta = "alert-danger";
        }
        finally
        {
            _isImporting = false;
        }
    }

    private async Task SincronizarTodas(bool enviarABalanza)
    {
        _isSyncing = true;
        _progressPercent = 0;
        _currentStep = 0;
        
        try
        {
            var balanzas = await DbContext.Balanzas.Where(b => b.IsEnabled).ToListAsync();
            var articulos = await DbContext.PluItems.ToListAsync();

            if (!balanzas.Any())
            {
                Mensaje = "No hay balanzas activas configuradas.";
                ClaseAlerta = "alert-warning";
                return;
            }

            // Calculo aproximado de pasos totales (balanzas * lotes de 1000)
            int batchSize = 1000;
            int batchesPerBalanza = (int)Math.Ceiling((double)articulos.Count / batchSize);
            if (batchesPerBalanza == 0) batchesPerBalanza = 1;
            _totalSteps = balanzas.Count * batchesPerBalanza;

            int exitos = 0;
            string batchId = Guid.NewGuid().ToString().Substring(0, 8).ToUpper();

            for (int bIdx = 0; bIdx < balanzas.Count; bIdx++)
            {
                var b = balanzas[bIdx];
                _statusMessage = $"Sincronizando {b.IpAddress}...";
                StateHasChanged();

                var res = await DigiService.SyncBalanzaAsync(b, articulos, enviarABalanza, (current, total) => {
                    // Este callback se llama en cada lote
                    _currentStep++;
                    _progressPercent = (int)((double)_currentStep / _totalSteps * 100);
                    _statusMessage = $"Balanza {b.IpAddress}: {current}/{total} PLUs";
                    StateHasChanged();
                }, batchId);

                b.LastSyncDate = DateTime.Now;
                b.LastSyncStatus = res.Message;
                
                if(res.Message.Contains("Exito") || res.Message.Contains("Generado"))
                {
                    exitos++;
                    if (!enviarABalanza && !string.IsNullOrEmpty(res.HexPayload))
                    {
                        string fileName = $"SM{b.IpAddress}F37.DAT";
                        await JS.InvokeVoidAsync("downloadTextFile", fileName, res.HexPayload);
                    }
                }
            }
            await DbContext.SaveChangesAsync();

            Mensaje = enviarABalanza ? $"Transmisión completada. {exitos} de {balanzas.Count} exitosas." : $"Módulos locales descargados para {balanzas.Count} balanzas.";
            ClaseAlerta = exitos == balanzas.Count ? "alert-success" : "alert-warning";
        }
        catch(Exception ex)
        {
            Mensaje = $"Error crítico en transmisión: {ex.Message}";
            ClaseAlerta = "alert-danger";
        }
        finally
        {
            _isSyncing = false;
        }
    }
}
