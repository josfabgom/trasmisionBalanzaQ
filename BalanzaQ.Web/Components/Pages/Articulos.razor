@page "/articulos"
@rendermode InteractiveServer
@using BalanzaQ.Web.Models
@using BalanzaQ.Web.Data
@using Microsoft.EntityFrameworkCore
@inject BalanzaDbContext DbContext
@inject BalanzaQ.Web.Services.DigiService DigiService
@inject BalanzaQ.Web.Services.ImportService ImportService
@inject IJSRuntime JS

<PageTitle>Artículos</PageTitle>

<div class="container mt-4">
    <style>
        .bg-success-soft { background-color: rgba(25, 135, 84, 0.1) !important; }
        .bg-danger-soft { background-color: rgba(220, 53, 69, 0.1) !important; }
        .bg-warning-soft { background-color: rgba(255, 193, 7, 0.1) !important; }
        .bg-primary-soft { background-color: rgba(13, 110, 253, 0.1) !important; }
        .bg-info-soft { background-color: rgba(13, 202, 240, 0.1) !important; }
        .bg-secondary-soft { background-color: rgba(108, 117, 125, 0.1) !important; }
        .xsmall { font-size: 0.7rem; }
        .uppercase { text-transform: uppercase; letter-spacing: 0.5px; }
        .table-hover tbody tr:hover { background-color: #f8fbff; cursor: pointer; transition: background 0.2s; }
        .btn-group .btn-white { background: white; border: 1px solid #dee2e6; }
        .btn-group .btn-white:hover { background: #f8f9fa; }
    </style>
    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded-3">
        <div>
            <h2 class="mb-0 fw-bold text-primary"><i class="bi bi-box-seam me-2"></i> Gestión de Artículos</h2>
            <p class="text-muted small mb-0">Administra los artículos sincronizados desde el archivo local y envíalos a las balanzas.</p>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <div class="input-group me-2" style="max-width:300px;">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                <input type="text" class="form-control border-start-0 ps-0" placeholder="Buscar PLU o nombre..." @bind="terminoBusqueda" @bind:event="oninput" @onkeyup="FiltrarLista" />
            </div>
            
            <div class="btn-group shadow-sm">
                <button class="btn btn-primary px-3" @onclick="() => SincronizarSeleccionados(true)" disabled="@(!seleccionados.Any() || _isSyncing)">
                    @if (_isSyncing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    else { <i class="bi bi-broadcast-pin me-1"></i> }
                    Transmitir Seleccionados
                </button>
                <button type="button" class="btn btn-primary dropdown-toggle dropdown-toggle-split" data-bs-toggle="dropdown" aria-expanded="false" disabled="@_isSyncing">
                    <span class="visually-hidden">Opciones extra</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                    <li><button class="dropdown-item py-2" @onclick="() => SincronizarSeleccionados(false)" disabled="@(!seleccionados.Any())">
                        <i class="bi bi-file-earmark-arrow-down me-2 text-primary"></i>Descargar Archivos .DAT
                    </button></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><button class="dropdown-item py-2" @onclick="SeleccionarFallidos">
                        <i class="bi bi-exclamation-triangle me-2 text-danger"></i>Seleccionar Fallidos
                    </button></li>
                </ul>
            </div>

            <button class="btn btn-outline-secondary" @onclick="SincronizarLocal" disabled="@_isSyncing" title="Sincronizar con data.dat">
                <i class="bi bi-arrow-repeat"></i>
            </button>
        </div>
    </div>

    @if (_isSyncing)
    {
        <div class="card mb-4 border-0 shadow-sm overflow-hidden anim-fade-in">
            <div class="card-body p-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fw-bold text-primary">
                        <i class="bi bi-gear-fill spin-slow me-2"></i>@_progressText
                    </span>
                    <span class="badge bg-primary-soft text-primary">@GetProgressPercentage()%</span>
                </div>
                <div class="progress" style="height: 10px; background-color: #f0f2f5; border-radius: 5px;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" 
                         role="progressbar" 
                         style="width: @(GetProgressPercentage())%; transition: width 0.3s ease; border-radius: 5px;" 
                         aria-valuenow="@_currentProgress" 
                         aria-valuemin="0" 
                         aria-valuemax="@_totalProgress">
                    </div>
                </div>
                @if(_totalProgress > 0)
                {
                    <div class="text-end mt-1">
                        <small class="text-muted">Procesando @_currentProgress de @_totalProgress registros</small>
                    </div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(Mensaje))
    {
        <div class="alert @ClaseAlerta alert-dismissible fade show shadow-sm border-0 d-flex align-items-center" role="alert">
            <i class="bi @(ClaseAlerta.Contains("success") ? "bi-check-circle-fill" : (ClaseAlerta.Contains("warning") ? "bi-exclamation-triangle-fill" : "bi-exclamation-circle-fill")) me-3 fs-4"></i>
            <div>
                @Mensaje
            </div>
            <button type="button" class="btn-close" @onclick="() => Mensaje = null"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle shadow-sm bg-white rounded-3 overflow-hidden border-0">
            <thead class="bg-primary text-white xsmall uppercase">
                <tr>
                    <th style="width: 40px;" class="ps-3">
                        <input type="checkbox" class="form-check-input border-white" @onchange="ToggleTodos" checked="@(listaFiltrada.Any() && seleccionados.Count >= listaFiltrada.Count)" />
                    </th>
                    <th class="py-3">PLU</th>
                    <th>PRODUCTO (TICKET)</th>
                    <th>PRECIO</th>
                    <th>ID SECC.</th>
                    <th>VTO.</th>
                    <th>TIPO</th>
                    <th>ESTADO</th>
                    <th class="pe-3 text-end">ACCIONES</th>
                </tr>
            </thead>
            <tbody class="small border-top-0">
                @foreach (var p in listaFiltrada)
                {
                    <tr>
                        <td class="ps-3">
                            <input type="checkbox" class="form-check-input" checked="@seleccionados.Contains(p.PluCode)" @onchange="(e) => ToggleSeleccion(p.PluCode, e)" />
                        </td>
                        <td class="fw-bold font-monospace">@p.PluCode</td>
                        <td>
                            <div class="fw-bold small">@p.ShortName</div>
                            <div class="text-muted xsmall">@p.Name</div>
                        </td>
                        <td class="fw-bold text-dark">$ @p.Price.ToString("N2")</td>
                        <td class="text-center"><span class="badge bg-light text-dark border">#@p.Section</span></td>
                        <td><span class="badge bg-secondary-soft text-secondary">@p.ShelfLife d</span></td>
                        <td>
                            @if (p.ItemType == "P") { <span class="badge bg-primary-soft text-primary"><i class="bi bi-scale me-1"></i>P.</span> }
                            else { <span class="badge bg-info-soft text-info"><i class="bi bi-box me-1"></i>U.</span> }
                        </td>
                        <td>
                            @if (p.LastSyncStatus == "Exitoso")
                            {
                                <span class="badge bg-success-soft text-success border-success-subtle" title="Sincronizado el @p.LastSyncDate?.ToString("g")"><i class="bi bi-check-circle me-1"></i>EXITO</span>
                            }
                            else if (p.LastSyncStatus == "Verificando")
                            {
                                <span class="badge bg-info-soft text-info border-info-subtle" title="Sincronizado el @p.LastSyncDate?.ToString("g")"><i class="bi bi-shield-shaded me-1"></i>CHECK</span>
                            }
                            else if (p.LastSyncStatus == "Fallo")
                            {
                                <span class="badge bg-danger-soft text-danger border-danger-subtle" title="@p.LastSyncError (el @p.LastSyncDate?.ToString("g") )"><i class="bi bi-x-circle me-1"></i>FALLO</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-muted opacity-75 border"><i class="bi bi-dash-circle me-1"></i>PEND.</span>
                            }
                        </td>
                        <td class="pe-3 text-end">
                             <div class="btn-group shadow-sm">
                                 <button class="btn btn-sm btn-white border-end" @onclick="() => Editar(p)" title="Editar PLU">
                                     <i class="bi bi-pencil text-primary"></i>
                                 </button>
                                 <button class="btn btn-sm btn-white" @onclick="() => Previsualizar(p)" title="Previsualizar Etiqueta">
                                     <i class="bi bi-eye text-secondary"></i>
                                 </button>
                             </div>
                         </td>
                     </tr>
                }
                @if(!listaFiltrada.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted p-4">No se encontraron artículos importados o con ese criterio de búsqueda. Importa el archivo data.dat en el Dashboard.</td></tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Inspección de Trama (Opcional, se mantiene para validación de PLU) -->
    @if (!string.IsNullOrEmpty(lastGeneratedHex))
    {
        <div class="card mt-4 border-primary shadow-sm mb-5">
            <div class="card-header bg-primary text-white d-flex justify-content-between">
                <span><i class="bi bi-code-square"></i> Inspección de Trama Generada (Hexadecimal)</span>
                <button class="btn btn-sm btn-light" @onclick="() => lastGeneratedHex = null">Cerrar</button>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <label class="fw-bold mb-2">Archivo .DAT generado:</label>
                        <textarea class="form-control font-monospace" rows="5" readonly style="font-size: 0.8rem; background: #f8f9fa;">@lastGeneratedHex</textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="fw-bold mb-2">Comparar con "Hex Bueno":</label>
                        <textarea class="form-control font-monospace" rows="5" @bind="hexBueno" placeholder="Pega aquí la trama que funciona..." style="font-size: 0.8rem;"></textarea>
                    </div>
                </div>
                
                @if (!string.IsNullOrEmpty(hexBueno))
                {
                    <div class="mt-2 p-2 rounded small" style="background: #e9ecef;">
                        <strong>Resultado:</strong> @(lastGeneratedHex.Equals(hexBueno?.Trim(), StringComparison.OrdinalIgnoreCase) ? "¡IDÉNTICAS!" : "Hay diferencias.")
                        <div class="xsmall text-muted mt-1">@GetDiffSummary()</div>
                    </div>
                }
            </div>
        </div>
    }
</div>


@if (ShowModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5); z-index: 1050;">
        <div class="modal-dialog modal-lg">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-pencil-square me-2"></i>Editar Artículo: @Model.PluCode</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Código PLU Base</label>
                            <input type="number" class="form-control bg-light" @bind="Model.PluCode" disabled />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Precio ($)</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" step="0.01" class="form-control text-success fw-bold" @bind="Model.Price" />
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Días Vencimiento</label>
                            <input type="number" class="form-control" @bind="Model.ShelfLife" />
                        </div>
                        
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Nombre en Etiqueta (Balanza)</label>
                            <input type="text" class="form-control" @bind="Model.ShortName" />
                            <small class="text-muted">Este nombre es el que se transmite a la balanza (máx 28 carac).</small>
                        </div>
                        
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Nombre Ticket / Referencia</label>
                            <input type="text" class="form-control" @bind="Model.Name" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Tipo de Artículo</label>
                            <select class="form-select" @bind="Model.ItemType">
                                <option value="P">Persable (Peso/kg)</option>
                                <option value="N">No Pesable (Unidad)</option>
                            </select>
                        </div>
                        
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Formato Etiqueta (F52)</label>
                            <input type="number" class="form-control" @bind="Model.LabelFormat" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Formato Barras (F37)</label>
                            <input type="number" class="form-control" @bind="Model.BarcodeFormat" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cerrar</button>
                    <button type="button" class="btn btn-primary px-4" @onclick="Guardar">
                        <i class="bi bi-save me-2"></i>Guardar Cambios
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowPreviewModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content shadow-lg border-0" style="border-radius: 12px; overflow: hidden;">
                <div class="modal-header bg-dark text-white border-0 py-2">
                    <h5 class="modal-title xsmall">Previsualización de Etiqueta (Simulador)</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => ShowPreviewModal = false"></button>
                </div>
                <div class="modal-body bg-light d-flex justify-content-center p-4">
                    <LabelSimulator Item="PreviewModel" />
                </div>
                <div class="modal-footer bg-light border-0 py-2">
                    <div class="xsmall text-muted me-auto">Nota: El diseño real depende de la configuración de la balanza.</div>
                    <button type="button" class="btn btn-sm btn-secondary" @onclick="() => ShowPreviewModal = false">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<PluItem> todosArticulos = new();
    private List<PluItem> listaFiltrada = new();
    private string? terminoBusqueda;
    private string? Mensaje;
    private string ClaseAlerta = "alert-info";
    private bool _isSyncing = false;
    private int _currentProgress = 0;
    private int _totalProgress = 0;
    private string _progressText = "";
    private HashSet<int> seleccionados = new();
    private PluItem Model = new();
    private PluItem PreviewModel = new();
    private bool ShowModal = false;
    private bool ShowPreviewModal = false;
    private string? lastGeneratedHex;
    private string? hexBueno;

    private int GetProgressPercentage() => _totalProgress > 0 ? (int)((double)_currentProgress / _totalProgress * 100) : 0;

    private string GetDiffSummary()
    {
        if (string.IsNullOrEmpty(lastGeneratedHex) || string.IsNullOrEmpty(hexBueno)) return "";
        string gen = lastGeneratedHex.ToUpper();
        string bue = hexBueno.Trim().ToUpper();
        int minLen = Math.Min(gen.Length, bue.Length);
        for(int i=0; i<minLen; i++) {
            if(gen[i] != bue[i]) return $"Primera diferencia en posición {i}: '{gen[i]}' vs '{bue[i]}'. Trama cerca: {gen.Substring(Math.Max(0,i-10), Math.Min(20, gen.Length - Math.Max(0,i-10)))}";
        }
        return gen.Length != bue.Length ? $"Diferencia en longitud: {gen.Length} vs {bue.Length}" : "Sin diferencias visibles.";
    }

    private void ToggleSeleccion(int pluCode, ChangeEventArgs e)
    {
        bool isChecked = (bool?)e.Value ?? false;
        if (isChecked) seleccionados.Add(pluCode);
        else seleccionados.Remove(pluCode);
    }

    private void ToggleTodos(ChangeEventArgs e)
    {
        bool isChecked = (bool?)e.Value ?? false;
        if (isChecked)
        {
            foreach (var p in listaFiltrada) seleccionados.Add(p.PluCode);
        }
        else
        {
            foreach (var p in listaFiltrada) seleccionados.Remove(p.PluCode);
        }
    }

    private void SeleccionarFallidos()
    {
        seleccionados.Clear();
        var fallidos = todosArticulos.Where(x => x.LastSyncStatus == "Fallo").ToList();
        foreach (var p in fallidos)
        {
            seleccionados.Add(p.PluCode);
        }
        Mensaje = fallidos.Any() ? $"Se han seleccionado {fallidos.Count} artículos fallidos." : "No hay artículos con estado de fallo.";
        ClaseAlerta = fallidos.Any() ? "alert-info" : "alert-light";
        FiltrarLista();
    }

    private async Task SincronizarLocal()
    {
        _isSyncing = true;
        _progressText = "Iniciando sincronización local...";
        _currentProgress = 0;
        _totalProgress = 0;
        StateHasChanged();

        try
        {
            string path = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "..", "data.dat");
            if (!File.Exists(path)) path = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "data.dat");
            
            if (File.Exists(path))
            {
                _progressText = "Leyendo archivo data.dat...";
                StateHasChanged();

                using var fs = new FileStream(path, FileMode.Open, FileAccess.Read);
                int importados = await ImportService.ImportarDatosAsync(fs, (current, total) => {
                    _currentProgress = current;
                    _totalProgress = total;
                    _progressText = $"Importando productos localmente: {current}/{total}";
                    StateHasChanged();
                }, "data.dat (ABM)");
                
                _progressText = "¡Importación completada!";
                StateHasChanged();

                Mensaje = $"Sincronización local exitosa. Se actualizaron {importados} artículos.";
                ClaseAlerta = "alert-success";
                await CargarDatos();
            }
            else
            {
                Mensaje = "No se encontró el archivo data.dat en la carpeta raíz.";
                ClaseAlerta = "alert-warning";
            }
        }
        catch (Exception ex)
        {
            Mensaje = $"Error en sincronización local: {ex.Message}";
            ClaseAlerta = "alert-danger";
        }
        finally
        {
            _isSyncing = false;
        }
    }

    private async Task SincronizarSeleccionados(bool enviarABalanza)
    {
        if (!seleccionados.Any()) return;
        _isSyncing = true;
        try
        {
            var balanzas = await DbContext.Balanzas.Where(b => b.IsEnabled).ToListAsync();
            var articulosSeleccionados = todosArticulos.Where(a => seleccionados.Contains(a.PluCode)).ToList();

            if (!balanzas.Any())
            {
                Mensaje = "No hay balanzas activas configuradas.";
                ClaseAlerta = "alert-warning";
                return;
            }

            int exitos = 0;
            _totalProgress = articulosSeleccionados.Count * balanzas.Count;
            _currentProgress = 0;
            int balanzaIndex = 0;
            string batchId = Guid.NewGuid().ToString().Substring(0, 8).ToUpper();

            foreach (var b in balanzas)
            {
                balanzaIndex++;
                _progressText = $"Conectando con {b.IpAddress} ({balanzaIndex}/{balanzas.Count})...";
                StateHasChanged();

                var res = await DigiService.SyncBalanzaAsync(b, articulosSeleccionados, enviarABalanza, (current, total) => {
                    _currentProgress = ((balanzaIndex - 1) * total) + current;
                    _progressText = $"Transmitiendo a {b.IpAddress}: {current}/{total} PLUs";
                    StateHasChanged();
                }, batchId);

                b.LastSyncDate = DateTime.Now;
                b.LastSyncStatus = res.Message;
                
                if (res.Message.Contains("Exito", StringComparison.OrdinalIgnoreCase) || 
                    res.Message.Contains("exitosos", StringComparison.OrdinalIgnoreCase) || 
                    res.Message.Contains("generad", StringComparison.OrdinalIgnoreCase))
                {
                    exitos++;
                    
                    if (!enviarABalanza && !string.IsNullOrEmpty(res.HexPayload))
                    {
                        var bytes = System.Text.Encoding.ASCII.GetBytes(res.HexPayload);
                        using var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
                        await JS.InvokeVoidAsync("downloadFileFromStream", $"SM{b.IpAddress}F37.DAT", streamRef);
                    }
                }
            }

            // PERSISTIR ESTADOS INDIVIDUALES
            await DbContext.SaveChangesAsync();

            if (enviarABalanza)
            {
                Mensaje = (exitos > 0) ? $"Transmisión completada. Se enviaron artículos a {exitos} balanza(s)." : "Error en el proceso de envío.";
            }
            else
            {
                Mensaje = (exitos > 0) ? $"Archivos .DAT generados y descargados para {exitos} balanza(s)." : "Error al generar los archivos.";
            }
            ClaseAlerta = (exitos > 0) ? "alert-success" : "alert-danger";
        }
        catch (Exception ex)
        {
            Mensaje = "Error critico: " + ex.Message;
            ClaseAlerta = "alert-danger";
        }
        finally
        {
            _isSyncing = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        todosArticulos = await DbContext.PluItems.OrderBy(p => p.PluCode).ToListAsync();
        FiltrarLista();
    }

    private void FiltrarLista()
    {
        if (string.IsNullOrWhiteSpace(terminoBusqueda))
        {
            listaFiltrada = todosArticulos.ToList();
        }
        else
        {
            var t = terminoBusqueda.ToLowerInvariant();
            listaFiltrada = todosArticulos.Where(p => 
                p.Name.ToLowerInvariant().Contains(t) || 
                p.PluCode.ToString().Contains(t) ||
                p.ShortName.ToLowerInvariant().Contains(t)
            ).ToList();
        }
    }

    private void Editar(PluItem p)
    {
        Model = new PluItem
        {
            Id = p.Id,
            PluCode = p.PluCode,
            Name = p.Name,
            ShortName = p.ShortName,
            Price = p.Price,
            ShelfLife = p.ShelfLife,
            ItemType = p.ItemType,
            LabelFormat = p.LabelFormat,
            BarcodeFormat = p.BarcodeFormat
        };
        ShowModal = true;
    }

    private void Previsualizar(PluItem p)
    {
        PreviewModel = p;
        ShowPreviewModal = true;
    }

    private async Task Guardar()
    {
        var dbItem = await DbContext.PluItems.FindAsync(Model.Id);
        if (dbItem != null)
        {
            dbItem.Name = Model.Name;
            dbItem.ShortName = Model.ShortName;
            dbItem.Price = Model.Price;
            dbItem.ShelfLife = Model.ShelfLife;
            dbItem.ItemType = Model.ItemType;
            dbItem.LabelFormat = Model.LabelFormat;
            dbItem.BarcodeFormat = Model.BarcodeFormat;
            await DbContext.SaveChangesAsync();
            
            Mensaje = $"Artículo {dbItem.PluCode} actualizado correctamente.";
            ClaseAlerta = "alert-success";
            await CargarDatos();
            ShowModal = false;
        }
    }

    private void CerrarModal()
    {
        ShowModal = false;
    }
}
