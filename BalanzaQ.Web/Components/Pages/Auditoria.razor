@page "/auditoria"
@rendermode InteractiveServer
@using BalanzaQ.Web.Models
@using BalanzaQ.Web.Data
@using Microsoft.EntityFrameworkCore
@using BalanzaQ.Web.Services
@inject BalanzaDbContext DbContext
@inject IJSRuntime JS
@inject DigiService DigiService

<PageTitle>Auditoría de Sistema</PageTitle>

<div class="header-premium d-flex justify-content-between align-items-center anim-fade-in shadow-sm">
    <div class="d-flex align-items-center">
        <div class="icon-box-md bg-primary-soft text-primary me-3 shadow-sm">
            <i class="bi bi-shield-check fs-3"></i>
        </div>
        <div>
            <h1 class="h4 mb-1 fw-bold text-dark">Auditoría del Sistema</h1>
            <p class="text-muted small mb-0">Seguimiento forense de transmisiones e importaciones en tiempo real.</p>
        </div>
    </div>
    <div class="text-end">
        <button class="btn btn-outline-danger rounded-pill px-3 shadow-sm btn-sm" @onclick="LimpiarAuditoria">
            <i class="bi bi-trash-fill me-2"></i> Borrar Historial
        </button>
    </div>
</div>

<div class="container-fluid px-0 anim-fade-in" style="animation-delay: 0.1s;">
    <ul class="nav nav-pills mb-4 p-1 bg-white shadow-sm rounded-pill border" style="width: fit-content;">
        <li class="nav-item">
            <button class="nav-link rounded-pill py-2 px-4 @(activeTab == "transmision" ? "active" : "")" @onclick='() => activeTab = "transmision"'>
                <i class="bi bi-broadcast me-2"></i> Transmisiones
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link rounded-pill py-2 px-4 @(activeTab == "importacion" ? "active" : "")" @onclick='() => activeTab = "importacion"'>
                <i class="bi bi-cloud-arrow-down me-2"></i> Importaciones
            </button>
        </li>
    </ul>

    @if (activeTab == "transmision")
    {
        @if (logSessions == null)
        {
            <div class="text-center p-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (!logSessions.Any())
        {
            <div class="alert alert-info border-0 shadow-sm rounded-4 anim-fade-in">No hay registros de transmisiones aún.</div>
        }
        else
        {
            @foreach (var session in logSessions)
            {
                <div class="card card-premium mb-3 shadow-sm border-0 rounded-4 overflow-hidden anim-fade-in shadow-hover">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center py-4 border-0" @onclick="() => ToggleSession(session.BatchId)" style="cursor: pointer;">
                        <div class="d-flex align-items-center ps-2">
                            <div class="icon-box-sm me-3 @(session.FailedCount > 0 ? "bg-danger-soft text-danger" : (session.HasWarnings ? "bg-info-soft text-info" : "bg-success-soft text-success")) shadow-sm">
                                <i class="bi @(session.FailedCount > 0 ? "bi-exclamation-triangle-fill" : (session.HasWarnings ? "bi-shield-fill-exclamation" : "bi-check-all")) fs-5"></i>
                            </div>
                            <div>
                                <span class="fw-bold d-block text-dark">Lote <span class="font-monospace text-primary">#@session.BatchId</span></span>
                                <div class="xsmall text-muted">
                                    <i class="bi bi-calendar3 me-1"></i> @session.StartTime.ToString("dd/MM/yyyy HH:mm") 
                                    <span class="ms-2 fw-bold"><i class="bi bi-clock me-1"></i> Hace @GetRelativeTime(session.StartTime)</span>
                                </div>
                            </div>
                        </div>
                        <div class="text-end d-flex align-items-center pe-2">
                            <div class="me-4 text-end d-none d-md-block">
                                @if (session.FailedCount > 0) { <span class="badge bg-danger-soft text-danger rounded-pill px-3">@session.FailedCount Errores</span> }
                                else if (session.HasWarnings) { <span class="badge bg-info-soft text-info rounded-pill px-3">En Verificación</span> }
                                else { <span class="badge bg-success-soft text-success rounded-pill px-3">Sincronización Exitosa</span> }
                                <div class="xsmall text-muted mt-1 fw-bold">@session.TotalItems registros procesados</div>
                            </div>
                            <div class="icon-box-sm bg-light text-muted rounded-circle">
                                <i class="bi @(expandedSessions.Contains(session.BatchId) ? "bi-chevron-up" : "bi-chevron-down")"></i>
                            </div>
                        </div>
                    </div>
                    @if (expandedSessions.Contains(session.BatchId))
                    {
                        <div class="card-body p-0 border-top anim-fade-in">
                            <div class="table-responsive">
                                <table class="table table-premium table-sm align-middle mb-0">
                                    <thead>
                                        <tr class="xsmall text-muted text-uppercase">
                                            <th class="ps-4">Hora</th><th>Equipo / IP</th><th class="text-center">PLU</th><th>Descripción</th><th>Estado</th><th class="pe-4">Resultado</th>
                                        </tr>
                                    </thead>
                                    <tbody class="small">
                                        @foreach (var log in session.Logs) {
                                            <tr>
                                                <td class="ps-4 text-muted">@log.Date.ToString("HH:mm:ss")</td>
                                                <td class="fw-bold text-dark">@log.BalanzaIp</td>
                                                <td class="text-center font-monospace text-primary fw-bold">@log.PluCode</td>
                                                <td class="fw-medium">@log.ProductName</td>
                                                <td>
                                                    <span class="badge rounded-pill px-3 @(log.Status == "Exitoso" ? "bg-success-soft text-success" : (log.Status == "Verificando" ? "bg-info-soft text-info" : "bg-danger-soft text-danger"))">
                                                        @(log.Status == "Exitoso" ? "Éxito" : (log.Status == "Verificando" ? "Validando" : "Error"))
                                                    </span>
                                                </td>
                                                <td class="pe-4 xsmall text-muted italic">@log.ErrorMessage</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <div class="p-3 bg-light-soft border-top d-flex justify-content-between align-items-center rounded-bottom-4">
                                <small class="text-muted xsmall ps-2"><i class="bi bi-info-circle me-2"></i> La verificación garantiza la integridad física de los datos en la balanza.</small>
                                <button class="btn btn-sm btn-primary rounded-pill px-4 shadow-sm" @onclick="() => VerificarLote(session)" disabled="@isVerifying">
                                    @if(verifyingBatchId == session.BatchId) { <span class="spinner-border spinner-border-sm me-2"></span> }
                                    else { <i class="bi bi-shield-shaded me-2"></i> }
                                    Verificar en Red
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        }
    }
    else
    {
        @if (importLogs == null)
        {
            <div class="text-center p-5"><div class="spinner-border text-primary"></div></div>
        }
        else if (!importLogs.Any())
        {
            <div class="alert alert-info border-0 shadow-sm rounded-4 anim-fade-in">No hay registros de importaciones de sistema aún.</div>
        }
        else
        {
            @foreach (var log in importLogs)
            {
                <div class="card card-premium mb-3 shadow-sm border-0 rounded-4 overflow-hidden anim-fade-in shadow-hover">
                    <div class="card-body d-flex justify-content-between align-items-center p-4">
                        <div class="d-flex align-items-center">
                            <div class="icon-box-md me-3 @(log.ErrorCount > 0 ? "bg-warning-soft text-warning" : "bg-primary-soft text-primary") shadow-sm">
                                <i class="bi @(log.ErrorCount > 0 ? "bi-journal-medical" : "bi-journal-check") fs-4"></i>
                            </div>
                            <div>
                                <h6 class="mb-1 fw-bold text-dark">@log.FileName</h6>
                                <div class="text-muted xsmall">
                                    <span class="me-2"><i class="bi bi-calendar3 me-1"></i> @log.Date.ToString("dd/MM/yyyy HH:mm")</span>
                                    <span class="fw-bold"><i class="bi bi-clock me-1"></i> Hace @GetRelativeTime(log.Date)</span>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex gap-4 text-center">
                            <div class="px-3 border-end">
                                <div class="fw-bold mb-0">@log.TotalRecords</div>
                                <div class="text-muted xsmall text-uppercase fw-bold">Líneas</div>
                            </div>
                            <div class="px-3 border-end">
                                <div class="fw-bold mb-0 text-success">@log.ProcessedRecords</div>
                                <div class="text-muted xsmall text-uppercase fw-bold">OK</div>
                            </div>
                            <div class="px-3">
                                <div class="fw-bold mb-0 @(log.ErrorCount > 0 ? "text-danger" : "text-muted")">@log.ErrorCount</div>
                                <div class="text-muted xsmall text-uppercase fw-bold">Err</div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-0 py-2 ps-4">
                        <small class="text-muted italic xsmall"><i class="bi bi-info-circle me-1"></i> @log.details</small>
                    </div>
                </div>
            }
        }
    }
</div>

<style>
    .bg-success-soft { background-color: rgba(25, 135, 84, 0.1) !important; }
    .bg-danger-soft { background-color: rgba(220, 53, 69, 0.1) !important; }
    .bg-warning-soft { background-color: rgba(255, 193, 7, 0.1) !important; }
    .bg-primary-soft { background-color: rgba(13, 110, 253, 0.1) !important; }
    .bg-info-soft { background-color: rgba(13, 202, 240, 0.1) !important; }
    .bg-secondary-soft { background-color: rgba(108, 117, 125, 0.1) !important; }
    
    .icon-box {
        width: 48px; height: 48px; border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
    }

    .icon-box-sm {
        width: 38px; height: 38px; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
    }
    
    .xsmall { font-size: 0.7rem; }
    .font-monospace { font-family: 'Consolas', monospace; }
    .shadow-hover:hover { transform: translateY(-2px); transition: all 0.2s ease; box-shadow: 0 .5rem 1rem rgba(0,0,0,.1)!important; }
    .table-hover tbody tr:hover { background-color: #f8fbff; transition: background 0.2s; }
</style>

@code {
    private string activeTab = "transmision";
    private List<LogSession> logSessions = new();
    private List<ImportLog> importLogs = new();
    private HashSet<string> expandedSessions = new();
    private bool isVerifying = false;
    private string? verifyingBatchId;

    protected override async Task OnInitializedAsync()
    {
        await CargarLogs();
    }

    private async Task CargarLogs()
    {
        // Logs de Transmisión
        var logs = await DbContext.SyncLogs.OrderByDescending(l => l.Date).Take(1000).ToListAsync();
        logSessions = logs.GroupBy(l => l.BatchId).Select(g => new LogSession {
            BatchId = g.Key,
            StartTime = g.Max(l => l.Date),
            TotalItems = g.Count(),
            FailedCount = g.Count(l => l.Status == "Fallo"),
            HasWarnings = g.Any(l => l.Status == "Verificando"),
            Logs = g.OrderBy(l => l.Date).ToList()
        }).OrderByDescending(s => s.StartTime).ToList();
        
        if (logSessions.Any()) expandedSessions.Add(logSessions.First().BatchId);

        // Logs de Importación
        importLogs = await DbContext.ImportLogs.OrderByDescending(l => l.Date).Take(50).ToListAsync();
    }

    private void ToggleSession(string id) => _ = expandedSessions.Contains(id) ? expandedSessions.Remove(id) : expandedSessions.Add(id);

    private async Task VerificarLote(LogSession session)
    {
        if (isVerifying) return;
        isVerifying = true;
        verifyingBatchId = session.BatchId;
        StateHasChanged();

        try
        {
            // Tomamos el último PLU del lote como centinela
            var lastLog = session.Logs.LastOrDefault();
            if (lastLog == null) return;

            bool exists = await DigiService.VerifyPLUInScaleAsync(lastLog.BalanzaIp ?? "", lastLog.PluCode);

            if (exists)
            {
                // Si el centinela existe, marcamos todos los "Verificando" de este lote como "Exitoso"
                var logsToFix = await DbContext.SyncLogs
                    .Where(l => l.BatchId == session.BatchId && l.Status == "Verificando")
                    .ToListAsync();

                foreach (var log in logsToFix)
                {
                    log.Status = "Exitoso";
                    log.ErrorMessage = "(Verificado mediante lectura RD)";
                }

                // También actualizar en los PluItems para que el listado se vea bien
                var pluCodes = logsToFix.Select(l => l.PluCode).Distinct().ToList();
                var items = await DbContext.PluItems.Where(p => pluCodes.Contains(p.PluCode)).ToListAsync();
                foreach(var it in items) 
                {
                    it.LastSyncStatus = "Exitoso";
                    it.LastSyncError = "(Verificado RD)";
                }

                await DbContext.SaveChangesAsync();
                await JS.InvokeVoidAsync("alert", "Lote Verificado: Se confirmó la presencia de los datos en la balanza correctamente.");
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Atención: La balanza no devolvió el registro solicitado. Verifique la conexión.");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Error en verificación: " + ex.Message);
        }
        finally
        {
            isVerifying = false;
            verifyingBatchId = null;
            await CargarLogs();
            StateHasChanged();
        }
    }

    private async Task LimpiarAuditoria()
    {
        if (await JS.InvokeAsync<bool>("confirm", "Se borrará todo el historial (envíos e importaciones). ¿Continuar?"))
        {
            DbContext.SyncLogs.RemoveRange(DbContext.SyncLogs);
            DbContext.ImportLogs.RemoveRange(DbContext.ImportLogs);
            await DbContext.SaveChangesAsync();
            await CargarLogs();
        }
    }

    private string GetRelativeTime(DateTime date)
    {
        var span = DateTime.Now - date;
        if (span.TotalMinutes < 1) return "instantes";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h";
        return $"{(int)span.TotalDays}d";
    }

    public class LogSession
    {
        public string BatchId { get; set; } = "";
        public DateTime StartTime { get; set; }
        public int TotalItems { get; set; }
        public int FailedCount { get; set; }
        public bool HasWarnings { get; set; }
        public List<SyncLog> Logs { get; set; } = new();
    }
}
