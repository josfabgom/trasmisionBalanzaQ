@page "/mantenimiento"
@rendermode InteractiveServer
@using BalanzaQ.Web.Models
@using BalanzaQ.Web.Data
@using Microsoft.EntityFrameworkCore
@inject BalanzaDbContext DbContext
@inject BalanzaQ.Web.Services.DigiService DigiService
@inject IJSRuntime JS

<PageTitle>Mantenimiento de Balanzas</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="display-6 fw-bold text-primary"><i class="bi bi-tools"></i> Centro de Mantenimiento Digi</h2>
            <p class="text-muted">Gestión directa de memoria y respaldos para balanzas SM-100/300.</p>
        </div>
    </div>

    @if (balanzas == null)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Cargando balanzas...</p>
        </div>
    }
    else if (!balanzas.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> No hay balanzas configuradas. Ve a <a href="balanzas">Configuración</a>.
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-dark text-white fw-bold">
                        1. Seleccionar Balanza
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            @foreach (var b in balanzas)
                            {
                                <button type="button" @onclick="() => SeleccionarBalanza(b)" 
                                        class="list-group-item list-group-item-action @(balanzaActual?.Id == b.Id ? "active" : "")">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1">@b.Description</h6>
                                        <small>@(b.IsEnabled ? "Activa" : "Inactiva")</small>
                                    </div>
                                    <small class="d-block">IP: @b.IpAddress</small>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                @if (balanzaActual != null)
                {
                    <div class="card shadow-sm border-warning h-100">
                        <div class="card-header bg-warning text-dark fw-bold d-flex justify-content-between align-items-center">
                            <span>2. Acciones Disponibles para: @balanzaActual.Description</span>
                            <span class="badge bg-dark">@balanzaActual.IpAddress</span>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6 text-center border-end p-4">
                                    <h5 class="card-title"><i class="bi bi-eraser-fill text-danger"></i> Limpieza de Tablas</h5>
                                    <p class="small text-muted">Elimina registros directamente de la memoria de la balanza.</p>
                                    <div class="d-grid gap-2">
                                        <button class="btn btn-outline-danger" @onclick='() => EjecutarMantenimiento("DELFI", 37)' disabled="@_isSyncing">
                                            Limpiar Tabla de PLUs (37)
                                        </button>
                                        <button class="btn btn-outline-danger" @onclick='() => EjecutarMantenimiento("DELFI", 32)' disabled="@(_isSyncing)">
                                            Limpiar Departamentos (32)
                                        </button>
                                    </div>
                                    <button class="btn btn-danger mt-3" @onclick="BorrarTodo" disabled="@_isSyncing">
                                        <i class="bi bi-trash"></i> RESET MASTER (Todo)
                                    </button>
                                </div>

                                <div class="col-md-6 text-center p-4">
                                    <h5 class="card-title"><i class="bi bi-cloud-download-fill text-info"></i> Respaldos (Read)</h5>
                                    <p class="small text-muted">Copia los datos de la balanza al servidor.</p>
                                    <div class="d-grid gap-2">
                                        <button class="btn btn-info text-white" @onclick='() => EjecutarMantenimiento("RD", 37)' disabled="@_isSyncing">
                                            Leer Respaldo de PLUs (37)
                                        </button>
                                        <button class="btn btn-outline-info" @onclick='() => EjecutarMantenimiento("RD", 52)' disabled="@_isSyncing">
                                            Leer Teclas Prefijadas (52)
                                        </button>
                                    </div>
                                    
                                    @if (!string.IsNullOrEmpty(_maintenanceResult) && _maintenanceResult.Contains("READ.DAT"))
                                    {
                                        <div class="mt-4 p-2 bg-light border rounded">
                                            <p class="small mb-1">Archivo listo en servidor</p>
                                            <button class="btn btn-sm btn-success w-100" @onclick="DescargarF37Read">
                                                <i class="bi bi-download"></i> Descargar Local
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(_maintenanceResult))
                            {
                                <div class="alert @_maintenanceClass mt-4 mb-0 animate__animated animate__fadeIn">
                                    <div class="d-flex align-items-center">
                                        @if (_isSyncing)
                                        {
                                            <div class="spinner-border spinner-border-sm me-3" role="status"></div>
                                        }
                                        else
                                        {
                                            <i class="bi bi-info-circle-fill me-3 fs-4"></i>
                                        }
                                        <div>@_maintenanceResult</div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-light xsmall">
                            <i class="bi bi-shield-exclamation text-warning"></i> 
                            Cuidado: Las operaciones de borrado son irreversibles en la balanza. Asegúrese de tener un respaldo antes de continuar.
                        </div>
                    </div>
                }
                else
                {
                    <div class="card h-100 bg-light border-0 d-flex align-items-center justify-content-center text-muted">
                        <div class="text-center">
                            <i class="bi bi-arrow-left-circle display-1 opacity-25"></i>
                            <h5 class="mt-3">Selecciona una balanza del panel izquierdo para comenzar.</h5>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private List<Balanza>? balanzas;
    private Balanza? balanzaActual;
    private bool _isSyncing = false;
    private string? _maintenanceResult;
    private string _maintenanceClass = "alert-info";

    protected override async Task OnInitializedAsync()
    {
        balanzas = await DbContext.Balanzas.ToListAsync();
        balanzaActual = balanzas.FirstOrDefault(b => b.IsEnabled);
    }

    private void SeleccionarBalanza(Balanza b)
    {
        balanzaActual = b;
        _maintenanceResult = null;
    }

    private async Task EjecutarMantenimiento(string cmd, int id)
    {
        if (balanzaActual == null) return;
        
        if (cmd == "DELFI")
        {
            bool confirmed = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de borrar la tabla {id} de la balanza {balanzaActual.Description}?");
            if (!confirmed) return;
        }

        _isSyncing = true;
        _maintenanceResult = $"Ejecutando {cmd} {id} en {balanzaActual.IpAddress}...";
        _maintenanceClass = "alert-info";
        StateHasChanged();

        var res = await DigiService.ExecuteMaintenanceCommandAsync(balanzaActual, cmd, id);
        _maintenanceResult = res;
        _maintenanceClass = res.Contains("Éxito") ? "alert-success" : "alert-danger";
        _isSyncing = false;
        StateHasChanged();
    }

    private async Task BorrarTodo()
    {
        if (balanzaActual == null) return;
        
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"ATENCIÓN: Se borrarán TODAS las tablas maestras de la balanza {balanzaActual.Description}. ¿Está COMPLETAMENTE seguro?");
        if (!confirmed) return;

        _isSyncing = true;
        _maintenanceResult = "Iniciando borrado integral...";
        _maintenanceClass = "alert-warning";
        StateHasChanged();

        int[] ids = { 32, 35, 37, 52, 55, 56, 58, 59, 65, 68 };
        foreach (var id in ids)
        {
            _maintenanceResult = $"Borrando tabla {id}...";
            StateHasChanged();
            await DigiService.ExecuteMaintenanceCommandAsync(balanzaActual, "DELFI", id);
        }

        _maintenanceResult = "Éxito: Borrado integral completado para la balanza.";
        _maintenanceClass = "alert-success";
        _isSyncing = false;
        StateHasChanged();
    }

    private async Task DescargarF37Read()
    {
        if (balanzaActual == null) return;
        string fileName = $"SM{balanzaActual.IpAddress}F37_READ.DAT";
        // Simulamos la descarga. En un entorno real se serviría el archivo.
        await JS.InvokeVoidAsync("alert", "Archivo de respaldo listo en el servidor como: " + fileName);
    }
}
