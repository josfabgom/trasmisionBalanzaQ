@page "/mantenimiento"
@rendermode InteractiveServer
@using BalanzaQ.Web.Models
@using BalanzaQ.Web.Data
@using Microsoft.EntityFrameworkCore
@inject BalanzaDbContext DbContext
@inject BalanzaQ.Web.Services.DigiService DigiService
@inject IJSRuntime JS
@inject BalanzaQ.Web.Services.BrandingService BrandingService

<PageTitle>Mantenimiento de Balanzas</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="display-6 fw-bold text-primary"><i class="bi bi-tools"></i> Centro de Mantenimiento Digi</h2>
            <p class="text-muted">Gestión directa de memoria y respaldos para balanzas SM-100/300.</p>
        </div>
    </div>

    @if (balanzas == null)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Cargando balanzas...</p>
        </div>
    }
    else if (!balanzas.Any())
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i> No hay balanzas configuradas. Ve a <a href="balanzas">Configuración</a>.
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-dark text-white fw-bold">
                        1. Seleccionar Balanza
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            @foreach (var b in balanzas)
                            {
                                <button type="button" @onclick="() => SeleccionarBalanza(b)" 
                                        class="list-group-item list-group-item-action @(balanzaActual?.Id == b.Id ? "active" : "")">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1">@b.Description</h6>
                                        <small>@(b.IsEnabled ? "Activa" : "Inactiva")</small>
                                    </div>
                                    <small class="d-block">IP: @b.IpAddress</small>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                @if (balanzaActual != null)
                {
                    <div class="card shadow-sm border-warning h-100">
                        <div class="card-header bg-warning text-dark fw-bold d-flex justify-content-between align-items-center">
                            <span>2. Acciones Disponibles para: @balanzaActual.Description</span>
                            <span class="badge bg-dark">@balanzaActual.IpAddress</span>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-6 text-center border-end p-4">
                                    <h5 class="card-title"><i class="bi bi-eraser-fill text-danger"></i> Limpieza de Tablas</h5>
                                    <p class="small text-muted">Elimina registros directamente de la memoria de la balanza.</p>
                                    <div class="d-grid gap-2">
                                        <button class="btn btn-outline-danger" @onclick='() => EjecutarMantenimiento("DELFI", 37)' disabled="@_isSyncing">
                                            Limpiar Tabla de PLUs (37)
                                        </button>
                                        <button class="btn btn-outline-danger" @onclick='() => EjecutarMantenimiento("DELFI", 32)' disabled="@(_isSyncing)">
                                            Limpiar Departamentos (32)
                                        </button>
                                    </div>
                                    <button class="btn btn-danger mt-3" @onclick="BorrarTodo" disabled="@_isSyncing">
                                        <i class="bi bi-trash"></i> RESET MASTER (Todo)
                                    </button>
                                </div>

                                <div class="col-md-6 text-center p-4">
                                    <h5 class="card-title"><i class="bi bi-cloud-download-fill text-info"></i> Respaldos (Read)</h5>
                                    <p class="small text-muted">Copia los datos de la balanza al servidor.</p>
                                    <div class="d-grid gap-2">
                                        <button class="btn btn-info text-white" @onclick='() => EjecutarMantenimiento("RD", 37)' disabled="@_isSyncing">
                                            Leer Respaldo de PLUs (37)
                                        </button>
                                        <button class="btn btn-outline-info" @onclick='() => EjecutarMantenimiento("RD", 52)' disabled="@_isSyncing">
                                            Leer Teclas Prefijadas (52)
                                        </button>
                                    </div>
                                    
                                    @if (!string.IsNullOrEmpty(_maintenanceResult) && _maintenanceResult.Contains("READ.DAT"))
                                    {
                                        <div class="mt-4 p-2 bg-light border rounded">
                                            <p class="small mb-1">Archivo listo en servidor</p>
                                            <button class="btn btn-sm btn-success w-100" @onclick="DescargarF37Read">
                                                <i class="bi bi-download"></i> Descargar Local
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(_maintenanceResult))
                            {
                                <div class="alert @_maintenanceClass mt-4 mb-0 animate__animated animate__fadeIn">
                                    <div class="d-flex align-items-center">
                                        @if (_isSyncing)
                                        {
                                            <div class="spinner-border spinner-border-sm me-3" role="status"></div>
                                        }
                                        else
                                        {
                                            <i class="bi bi-info-circle-fill me-3 fs-4"></i>
                                        }
                                        <div>@_maintenanceResult</div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="card-footer bg-light xsmall">
                            <i class="bi bi-shield-exclamation text-warning"></i> 
                            Cuidado: Las operaciones de borrado son irreversibles en la balanza. Asegúrese de tener un respaldo antes de continuar.
                        </div>
                    </div>
                }
                else
                {
                    <div class="card h-100 bg-light border-0 d-flex align-items-center justify-content-center text-muted">
                        <div class="text-center">
                            <i class="bi bi-arrow-left-circle display-1 opacity-25"></i>
                            <h5 class="mt-3">Selecciona una balanza del panel izquierdo para comenzar.</h5>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="row g-4 mt-2 mb-5">
        <div class="col-md-12">
            <div class="card shadow-sm border-primary anim-fade-in">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="bi bi-gear-fill me-2"></i> Configuración de Importación de Datos
                </div>
                <div class="card-body p-4">
                    <div class="row align-items-end">
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Separador de Columnas (.DAT)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-distribute-vertical"></i></span>
                                <input type="text" class="form-control border-primary" @bind="separatorValue" maxlength="5" placeholder="Ej: ; o , o |" />
                            </div>
                            <small class="text-muted">Actual: <span class="badge bg-light text-dark">@(string.IsNullOrEmpty(separatorValue) ? "Vacío" : separatorValue)</span></small>
                        </div>
                        <div class="col-md-3">
                            <button class="btn btn-primary w-100" @onclick="GuardarConfiguracion">
                                <i class="bi bi-save me-2"></i> Guardar Configuración
                            </button>
                        </div>
                        <div class="col-md-5">
                            @if (!string.IsNullOrEmpty(configMessage))
                            {
                                <div class="alert alert-success py-2 mb-0 animate__animated animate__fadeIn">
                                    <i class="bi bi-check-circle me-2"></i> @configMessage
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light xsmall text-muted">
                    Nota: Este separador se aplicará tanto a la importación manual como a la sincronización local automática.
                </div>
            </div>
        </div>
    </div>
    
    <div class="row g-4 mt-2 mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm border-info anim-fade-in">
                <div class="card-header bg-info text-white fw-bold">
                    <i class="bi bi-person-badge-fill me-2"></i> Identidad Corporativa & Branding
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <!-- Logo Section -->
                        <div class="col-md-3 text-center border-end">
                            <label class="form-label fw-bold d-block">Logo de Empresa</label>
                            <div class="mb-3 position-relative">
                                @if (!string.IsNullOrEmpty(businessLogoBase64))
                                {
                                    <div class="p-2 border rounded bg-white shadow-sm mb-2" style="height: 120px; display: flex; align-items: center; justify-content: center;">
                                        <img src="data:image/png;base64,@businessLogoBase64" class="img-fluid" style="max-height: 100px;" alt="Logo Preview" />
                                    </div>
                                }
                                else
                                {
                                    <div class="p-2 border border-dashed rounded bg-light mb-2 d-flex align-items-center justify-content-center" style="height: 120px;">
                                        <i class="bi bi-image text-muted display-4"></i>
                                    </div>
                                }
                                <label for="logoInput" class="btn btn-outline-info btn-sm w-100">
                                    <i class="bi bi-upload"></i> Subir Logo
                                </label>
                                <InputFile id="logoInput" OnChange="OnLogoSelected" accept="image/png,image/jpeg" style="display: none;" />
                            </div>
                            <small class="text-muted d-block">Formato: PNG/JPG (Recomendado: 200x200px)</small>
                        </div>

                        <!-- Info Section -->
                        <div class="col-md-9">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Nombre de la Empresa</label>
                                    <input type="text" class="form-control" @bind="businessName" placeholder="Nombre que verán los usuarios" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Teléfono de Contacto</label>
                                    <input type="text" class="form-control" @bind="businessPhone" placeholder="+56 9 ..." />
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold">Dirección Física</label>
                                    <input type="text" class="form-control" @bind="businessAddress" placeholder="Calle, Ciudad, Región" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Correo Electrónico</label>
                                    <input type="email" class="form-control" @bind="businessEmail" placeholder="contacto@empresa.com" />
                                </div>
                                <div class="col-md-6 align-self-end">
                                    <button class="btn btn-info text-white w-100 fw-bold" @onclick="GuardarBranding" disabled="@_isSavingBranding">
                                        @if (_isSavingBranding)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                            <span>Guardando...</span>
                                        }
                                        else
                                        {
                                            <span><i class="bi bi-save-fill me-2"></i> Guardar Identidad</span>
                                        }
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(_brandingMessage))
                    {
                        <div class="alert alert-success mt-3 py-2 animate__animated animate__fadeIn">
                            <i class="bi bi-check-circle-fill me-2"></i> @_brandingMessage
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2 mb-5">

        <div class="col-md-12">
            <div class="card shadow-sm border-dark">
                <div class="card-header bg-dark text-white fw-bold">
                    <i class="bi bi-terminal-fill me-2"></i> Consola de Pruebas Hex (Trama Cruda)
                </div>
                <div class="card-body">
                    <p class="text-muted small">Usa esta sección para enviar una trama hexadecimal manualmente a la balanza seleccionada (Archivo 37). Ideal para probar cambios en el pre-empaque.</p>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Trama Hexadecimal (PLU)</label>
                        <textarea class="form-control font-monospace" rows="4" @bind="_rawHex" placeholder="Pega aquí el HEX (ej: 0000002200397D00CD210D...)"></textarea>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <button class="btn btn-warning" @onclick="EnviarHexManual" disabled="@(_isSyncing || balanzaActual == null)">
                            <i class="bi bi-send-fill me-2"></i> Enviar Trama Manual (F37)
                        </button>
                        @if (!string.IsNullOrEmpty(_hexResult))
                        {
                            <span class="badge @(_hexResult.Contains("Éxito") ? "bg-success" : "bg-danger") p-2 animate__animated animate__pulse">
                                @_hexResult
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Balanza>? balanzas;
    private Balanza? balanzaActual;
    private bool _isSyncing = false;
    private string? _maintenanceResult;
    private string _maintenanceClass = "alert-info";
    
    // Configuración
    private string separatorValue = ";";
    private string? configMessage;

    // Pruebas Hex Crudas
    private string _rawHex = "";
    private string? _hexResult;

    // Branding
    private string businessName = "";
    private string businessAddress = "";
    private string businessEmail = "";
    private string businessPhone = "";
    private string businessLogoBase64 = "";
    private bool _isSavingBranding = false;
    private string? _brandingMessage;

    protected override async Task OnInitializedAsync()
    {
        balanzas = await DbContext.Balanzas.ToListAsync();
        balanzaActual = balanzas.FirstOrDefault(b => b.IsEnabled);
        
        var setting = await DbContext.AppSettings.FirstOrDefaultAsync(s => s.Key == "ImportSeparator");
        separatorValue = setting?.Value ?? ";";

        // Cargar Branding
        businessName = BrandingService.BusinessName;
        businessAddress = BrandingService.BusinessAddress;
        businessEmail = BrandingService.BusinessEmail;
        businessPhone = BrandingService.BusinessPhone;
        businessLogoBase64 = BrandingService.BusinessLogoBase64;
    }

    private void SeleccionarBalanza(Balanza b)
    {
        balanzaActual = b;
        _maintenanceResult = null;
    }

    private async Task EjecutarMantenimiento(string cmd, int id)
    {
        if (balanzaActual == null) return;
        
        if (cmd == "DELFI")
        {
            bool confirmed = await JS.InvokeAsync<bool>("confirm", $"¿Está seguro de borrar la tabla {id} de la balanza {balanzaActual.Description}?");
            if (!confirmed) return;
        }

        _isSyncing = true;
        _maintenanceResult = $"Ejecutando {cmd} {id} en {balanzaActual.IpAddress}...";
        _maintenanceClass = "alert-info";
        StateHasChanged();

        var res = await DigiService.ExecuteMaintenanceCommandAsync(balanzaActual, cmd, id);
        _maintenanceResult = res;
        _maintenanceClass = res.Contains("Éxito") ? "alert-success" : "alert-danger";
        _isSyncing = false;
        StateHasChanged();
    }

    private async Task BorrarTodo()
    {
        if (balanzaActual == null) return;
        
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"ATENCIÓN: Se borrarán TODAS las tablas maestras de la balanza {balanzaActual.Description}. ¿Está COMPLETAMENTE seguro?");
        if (!confirmed) return;

        _isSyncing = true;
        _maintenanceResult = "Iniciando borrado integral...";
        _maintenanceClass = "alert-warning";
        StateHasChanged();

        int[] ids = { 32, 35, 37, 52, 55, 56, 58, 59, 65, 68 };
        foreach (var id in ids)
        {
            _maintenanceResult = $"Borrando tabla {id}...";
            StateHasChanged();
            await DigiService.ExecuteMaintenanceCommandAsync(balanzaActual, "DELFI", id);
        }

        _maintenanceResult = "Éxito: Borrado integral completado para la balanza.";
        _maintenanceClass = "alert-success";
        _isSyncing = false;
        StateHasChanged();
    }

    private async Task DescargarF37Read()
    {
        if (balanzaActual == null) return;
        string fileName = $"SM{balanzaActual.IpAddress}F37_READ.DAT";
        // Simulamos la descarga. En un entorno real se serviría el archivo.
        await JS.InvokeVoidAsync("alert", "Archivo de respaldo listo en el servidor como: " + fileName);
    }
    private async Task GuardarConfiguracion()
    {
        var setting = await DbContext.AppSettings.FirstOrDefaultAsync(s => s.Key == "ImportSeparator");
        if (setting == null)
        {
            setting = new AppSetting { Key = "ImportSeparator", Value = separatorValue };
            DbContext.AppSettings.Add(setting);
        }
        else
        {
            setting.Value = separatorValue;
        }
        
        await DbContext.SaveChangesAsync();
        configMessage = "Configuración guardada correctamente.";
        StateHasChanged();
        
        await Task.Delay(3000);
        configMessage = null;
        StateHasChanged();
    }

    private async Task EnviarHexManual()
    {
        if (balanzaActual == null || string.IsNullOrWhiteSpace(_rawHex)) return;
        
        _isSyncing = true;
        _hexResult = "Enviando...";
        StateHasChanged();
        
        _hexResult = await DigiService.SendRawHexAsync(balanzaActual, _rawHex);
        _isSyncing = false;
        StateHasChanged();
    }

    private async Task OnLogoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        // Validar tamaño (máx 512KB para no saturar SQLite)
        if (file.Size > 512 * 1024)
        {
            await JS.InvokeVoidAsync("alert", "El logo es demasiado pesado. Máximo 512KB.");
            return;
        }

        using var stream = file.OpenReadStream(512 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        businessLogoBase64 = Convert.ToBase64String(ms.ToArray());
    }

    private async Task GuardarBranding()
    {
        _isSavingBranding = true;
        _brandingMessage = null;
        StateHasChanged();

        try
        {
            var data = new Dictionary<string, string>
            {
                { "BusinessName", businessName },
                { "BusinessAddress", businessAddress },
                { "BusinessEmail", businessEmail },
                { "BusinessPhone", businessPhone },
                { "BusinessLogo", businessLogoBase64 }
            };

            foreach (var kvp in data)
            {
                var setting = await DbContext.AppSettings.FirstOrDefaultAsync(s => s.Key == kvp.Key);
                if (setting == null)
                {
                    DbContext.AppSettings.Add(new AppSetting { Key = kvp.Key, Value = kvp.Value ?? "" });
                }
                else
                {
                    setting.Value = kvp.Value ?? "";
                }
            }

            await DbContext.SaveChangesAsync();
            await BrandingService.RefreshAsync();
            
            _brandingMessage = "Identidad corporativa actualizada correctamente.";
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Error al guardar branding: " + ex.Message);
        }
        finally
        {
            _isSavingBranding = false;
            StateHasChanged();
            await Task.Delay(3000);
            _brandingMessage = null;
            StateHasChanged();
        }
    }
}
