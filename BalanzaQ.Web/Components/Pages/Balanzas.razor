@page "/balanzas"
@rendermode InteractiveServer
@using BalanzaQ.Web.Models
@using BalanzaQ.Web.Data
@using Microsoft.EntityFrameworkCore
@inject BalanzaDbContext DbContext

<PageTitle>Balanzas</PageTitle>

<div class="header-premium d-flex justify-content-between align-items-center anim-fade-in shadow-sm">
    <div class="d-flex align-items-center">
        <div class="icon-box-md bg-info-soft text-info me-3 shadow-sm">
            <i class="bi bi-pc-display-horizontal fs-3"></i>
        </div>
        <div>
            <h1 class="h4 mb-1 fw-bold text-dark">Configuración de Balanzas</h1>
            <p class="text-muted small mb-0">Gestione la red de equipos Digi SM-300 y verifique su conectividad.</p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-info rounded-pill px-3 shadow-sm" @onclick="VerificarConexionGlobal" disabled="@_isPinging">
            @if (_isPinging) { <span class="spinner-border spinner-border-sm me-2"></span> }
            else { <i class="bi bi-activity me-2"></i> }
            Verificar Red
        </button>
        <button class="btn btn-primary rounded-pill px-4 shadow-sm" @onclick="CrearNueva">
            <i class="bi bi-plus-lg me-2"></i> Nueva Balanza
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(Mensaje))
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 anim-fade-in mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @Mensaje
        <button type="button" class="btn-close" @onclick="() => Mensaje = null"></button>
    </div>
}

<div class="card card-premium shadow-sm border-0 anim-fade-in" style="animation-delay: 0.1s;">
    <div class="table-responsive">
        <table class="table table-premium align-middle mb-0">
            <thead>
                <tr>
                    <th class="ps-4">Dirección IP</th>
                    <th class="text-center">Estado Red</th>
                    <th>Descripción / Sector</th>
                    <th class="text-center">Transmisión</th>
                    <th class="text-center">Último Envío</th>
                    <th class="text-end pe-4">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in balanzas)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="fw-bold text-dark">@b.IpAddress</div>
                            <div class="xsmall text-muted">ID: #@b.Id</div>
                        </td>
                        <td class="text-center">
                            @if (_pingStatus.ContainsKey(b.Id))
                            {
                                @if (_pingStatus[b.Id].Contains("✅"))
                                {
                                    <span class="badge bg-success-soft text-success rounded-pill px-3 py-1">
                                        <i class="bi bi-check-circle-fill me-1"></i> En línea
                                    </span>
                                }
                                else if (_pingStatus[b.Id].Contains("❌"))
                                {
                                    <span class="badge bg-danger-soft text-danger rounded-pill px-3 py-1">
                                        <i class="bi bi-x-circle-fill me-1"></i> Desconectado
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-soft text-secondary rounded-pill px-3 py-1">
                                        <i class="bi bi-hourglass-split me-1"></i> @_pingStatus[b.Id]
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-light text-dark rounded-pill px-3 py-1 border">? Desconocido</span>
                            }
                        </td>
                        <td>
                            <span class="text-dark fw-medium">@b.Description</span>
                        </td>
                        <td class="text-center">
                            @if (b.IsEnabled) { <span class="badge bg-primary-soft text-primary rounded-pill px-3 py-1">Activa</span> }
                            else { <span class="badge bg-light text-muted rounded-pill px-3 py-1">Inactiva</span> }
                        </td>
                        <td class="text-center">
                            <div class="xsmall fw-bold text-dark">@(b.LastSyncDate?.ToString("dd/MM HH:mm") ?? "Sin datos")</div>
                            <div class="xsmall text-muted truncate mx-auto" style="max-width: 150px;">@b.LastSyncStatus</div>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group shadow-sm rounded-3 overflow-hidden border">
                                <button class="btn btn-sm btn-white bg-white text-primary border-0 border-end py-2 px-3" @onclick="() => Editar(b)" title="Editar"><i class="bi bi-pencil-square"></i></button>
                                <button class="btn btn-sm btn-white bg-white text-info border-0 border-end py-2 px-3" @onclick="() => ConsultarEtiquetas(b)" title="Obtener F52"><i class="bi bi-printer-fill"></i></button>
                                <button class="btn btn-sm btn-white bg-white text-danger border-0 py-2 px-3" @onclick="() => Eliminar(b)" title="Eliminar"><i class="bi bi-trash-fill"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (ShowModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(Model.Id == 0 ? "Nueva Balanza" : "Editar Balanza")</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label>Dirección IP</label>
                        <input type="text" class="form-control" @bind="Model.IpAddress" placeholder="Ej: 192.168.1.100" />
                    </div>
                    <div class="mb-3">
                        <label>Descripción / Sector</label>
                        <input type="text" class="form-control" @bind="Model.Description" placeholder="Ej: Fiambreria 1" />
                    </div>
                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="switchEnabled" @bind="Model.IsEnabled">
                        <label class="form-check-label" for="switchEnabled">Activa (Transmitir datos a esta balanza)</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button type="button" class="btn btn-primary" @onclick="Guardar">Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

@inject BalanzaQ.Web.Services.DigiService DigiService
@inject IJSRuntime JSRuntime

@code {
    private List<Balanza> balanzas = new();
    private Balanza Model = new();
    private bool ShowModal = false;
    private string? Mensaje;
    
    private Dictionary<int, string> _pingStatus = new();
    private bool _isPinging = false;

    private async Task ConsultarEtiquetas(Balanza b)
    {
        Mensaje = $"Consultando etiquetas de {b.IpAddress}...";
        StateHasChanged();

        var success = await DigiService.GetEtiquetasAsync(b.IpAddress);
        if (success)
        {
            Mensaje = $"Archivo F52 de {b.IpAddress} obtenido correctamente en la carpeta Digi.";
        }
        else
        {
            Mensaje = $"Error al obtener etiquetas de {b.IpAddress}.";
        }
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        // Fire and forget al inicio
        _ = VerificarConexionGlobal();
    }

    private async Task CargarDatos()
    {
        balanzas = await DbContext.Balanzas.ToListAsync();
    }

    private async Task VerificarConexionGlobal()
    {
        if (!balanzas.Any()) return;

        _isPinging = true;
        _pingStatus.Clear();
        StateHasChanged();

        using var pinger = new System.Net.NetworkInformation.Ping();
        foreach(var b in balanzas)
        {
            _pingStatus[b.Id] = "🕒 Pinging...";
            StateHasChanged();
            
            try
            {
                var pingReply = await pinger.SendPingAsync(b.IpAddress, 1500); // 1.5s timeout
                if (pingReply.Status == System.Net.NetworkInformation.IPStatus.Success)
                {
                    _pingStatus[b.Id] = $"✅ Online ({pingReply.RoundtripTime}ms)";
                }
                else
                {
                    _pingStatus[b.Id] = $"❌ Offline ({pingReply.Status})";
                }
            }
            catch(Exception)
            {
                _pingStatus[b.Id] = "❌ Offline";
            }
        }
        _isPinging = false;
        StateHasChanged();
    }

    private void CrearNueva()
    {
        Model = new Balanza();
        ShowModal = true;
    }

    private void Editar(Balanza b)
    {
        Model = new Balanza
        {
            Id = b.Id,
            IpAddress = b.IpAddress,
            Description = b.Description,
            IsEnabled = b.IsEnabled,
            LastSyncDate = b.LastSyncDate,
            LastSyncStatus = b.LastSyncStatus
        };
        ShowModal = true;
    }

    private async Task Eliminar(Balanza b)
    {
        DbContext.Balanzas.Remove(b);
        await DbContext.SaveChangesAsync();
        _pingStatus.Remove(b.Id);
        Mensaje = "Balanza eliminada.";
        await CargarDatos();
    }

    private async Task Guardar()
    {
        if (Model.Id == 0)
        {
            DbContext.Balanzas.Add(Model);
        }
        else
        {
            var dbItem = await DbContext.Balanzas.FindAsync(Model.Id);
            if (dbItem != null)
            {
                dbItem.IpAddress = Model.IpAddress;
                dbItem.Description = Model.Description;
                dbItem.IsEnabled = Model.IsEnabled;
            }
        }
        await DbContext.SaveChangesAsync();
        ShowModal = false;
        Mensaje = "Balanza guardada exitosamente.";
        await CargarDatos();
        // Verificar red de la nueva
        _ = VerificarConexionGlobal();
    }

    private void CerrarModal()
    {
        ShowModal = false;
    }
}
