@page "/etiquetas"
@rendermode InteractiveServer
@using System.IO
@using BalanzaQ.Web.Models
@using BalanzaQ.Web.Data
@using Microsoft.EntityFrameworkCore
@inject IJSRuntime JSRuntime
@inject BalanzaDbContext DbContext
@inject BalanzaQ.Web.Services.DigiService DigiService

<PageTitle>Formatos de Etiqueta</PageTitle>

<div class="header-premium d-flex justify-content-between align-items-center anim-fade-in shadow-sm">
    <div class="d-flex align-items-center">
        <div class="icon-box-md bg-primary-soft text-primary me-3 shadow-sm">
            <i class="bi bi-printer fs-3"></i>
        </div>
        <div>
            <h1 class="h4 mb-1 fw-bold text-dark">Formatos de Etiqueta</h1>
            <p class="text-muted small mb-0">Gestione y previsualice los archivos F52 obtenidos de sus balanzas.</p>
        </div>
    </div>
    <div class="text-end">
        <button class="btn btn-outline-primary rounded-pill px-3 shadow-sm" @onclick="CargarArchivos">
            <i class="bi bi-arrow-clockwise me-2"></i> Refrescar
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(Mensaje))
{
    <div class="alert alert-info alert-dismissible fade show shadow-sm border-0 anim-fade-in mb-4" role="alert">
        <i class="bi bi-info-circle-fill me-2"></i> @Mensaje
        <button type="button" class="btn-close" @onclick="() => Mensaje = null"></button>
    </div>
}

<div class="row g-4 anim-fade-in" style="animation-delay: 0.1s;">
    <div class="col-lg-7">
        <div class="card card-premium shadow-sm border-0 h-100">
            <div class="card-header bg-white border-0 py-3 ps-4">
                <h6 class="fw-bold mb-0 text-dark">Módulos F52 Locales</h6>
            </div>
            <div class="card-body p-0" style="max-height: 600px; overflow-y: auto;">
                @if (archivos.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var file in archivos)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center px-4 py-3 border-0 border-bottom">
                                <div class="d-flex align-items-center">
                                    <div class="icon-box-sm bg-light text-primary me-3">
                                        <i class="bi bi-file-earmark-binary"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@file.Name</div>
                                        <div class="xsmall text-muted">@( (file.Length / 1024.0).ToString("F2") ) KB | Mod: @file.LastWriteTime.ToString("dd/MM HH:mm")</div>
                                    </div>
                                </div>
                                <div class="btn-group shadow-sm rounded-3 overflow-hidden" style="border: 1px solid #eee;">
                                    <button class="btn btn-sm btn-white bg-white text-primary border-0" @onclick="() => Visualizar(file.Name)"><i class="bi bi-pencil-square"></i></button>
                                    <button class="btn btn-sm btn-white bg-white text-danger border-0" @onclick="() => Eliminar(file.FullName)"><i class="bi bi-trash"></i></button>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-folder-x display-4 text-muted opacity-25"></i>
                        <p class="text-muted mt-3">No se encontraron archivos en la carpeta Digi.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card card-premium shadow-sm border-0 border-top border-primary border-4" style="border-top: 4px solid #0d6efd !important;">
            <div class="card-header bg-white border-0 py-3 ps-4">
                <h6 class="fw-bold mb-0 text-dark">Subir / Enviar Diseño</h6>
            </div>
            <div class="card-body p-4">
                <div class="mb-4">
                    <label class="form-label xsmall text-uppercase fw-bold text-muted mb-2">Balanza de destino (IP)</label>
                    <select class="form-select border-0 bg-light rounded-3 py-2" @bind="SelectedBalanzaIp">
                        <option value="">-- Seleccionar Equipo --</option>
                        @foreach (var b in balanzas)
                        {
                            <option value="@b.IpAddress">@b.Description (@b.IpAddress)</option>
                        }
                    </select>
                </div>
                
                <div class="mb-4">
                    <label class="form-label xsmall text-uppercase fw-bold text-muted mb-2">Archivo .DAT</label>
                    <InputFile OnChange="UploadFile" class="form-control border-0 bg-light rounded-3 py-2" />
                </div>

                <button class="btn btn-primary w-100 py-3 shadow-sm rounded-3" @onclick="EnviarABalanza" disabled="@string.IsNullOrEmpty(SelectedBalanzaIp)">
                    <i class="bi bi-send-fill me-2"></i> Transmitir Formato F52
                </button>
                
                <div class="mt-4 p-3 bg-primary-soft rounded-3">
                    <small class="text-primary xsmall d-flex">
                        <i class="bi bi-info-circle-fill me-3 fs-5"></i>
                        <span>Este proceso enviará el diseño de etiqueta a la balanza seleccionada de forma inmediata.</span>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@if (selectedFormat != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.6); z-index: 1060;">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title">Diseño: @selectedFormat.FileName</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => selectedFormat = null"></button>
                </div>
                <div class="modal-body bg-light p-4">
                    <div class="row">
                        <div class="col-lg-8 border-end text-center overflow-auto" style="max-height: 70vh;">
                            <div class="mx-auto bg-white shadow" style="width: @(selectedFormat.WidthLabel)px; height: @(selectedFormat.HeightLabel)px; position: relative; border: 1px solid #333;">
                                @foreach (var field in selectedFormat.Fields)
                                {
                                    <div @onclick="() => { selectedField = field; StateHasChanged(); }"
                                         class="p-1 @(selectedField == field ? "bg-primary text-white border-primary" : "bg-light text-dark border-secondary")"
                                         style="position: absolute; left: @(field.X)px; top: @(field.Y)px; border: 2px dashed; cursor: pointer; font-size: 11px; white-space: nowrap; z-index: @(selectedField == field ? 10 : 1)">
                                        @field.FieldName
                                    </div>
                                }
                                @if (!selectedFormat.Fields.Any())
                                {
                                    <div class="d-flex align-items-center justify-content-center h-100 text-muted">
                                        <em>Agregue campos desde el panel lateral</em>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="card border-0 shadow-sm">
                                <div class="card-header bg-primary text-white">Propiedades</div>
                                <div class="card-body">
                                    @if (selectedField != null)
                                    {
                                        <div class="d-flex justify-content-between mb-3">
                                            <strong>@selectedField.FieldName</strong>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => { selectedFormat.Fields.Remove(selectedField); selectedField = null; }"><i class="bi bi-trash"></i></button>
                                        </div>
                                        <div class="mb-2">
                                            <label class="small">Posición X</label>
                                            <input type="number" class="form-control form-control-sm" @bind="selectedField.X" />
                                        </div>
                                        <div class="mb-2">
                                            <label class="small">Posición Y</label>
                                            <input type="number" class="form-control form-control-sm" @bind="selectedField.Y" />
                                        </div>
                                        <div class="btn-group w-100 mb-3">
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => { if(selectedField!=null) selectedField.X-=5; }">←</button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => { if(selectedField!=null) selectedField.X+=5; }">→</button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => { if(selectedField!=null) selectedField.Y-=5; }">↑</button>
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => { if(selectedField!=null) selectedField.Y+=5; }">↓</button>
                                        </div>
                                    }
                                    <hr />
                                    <label class="small fw-bold">Añadir Campo</label>
                                    <div class="input-group input-group-sm mb-3">
                                        <select class="form-select" @bind="newFieldId">
                                            <option value="0">-- Seleccionar --</option>
                                            <option value="1">Nombre</option>
                                            <option value="2">Precio U</option>
                                            <option value="3">Peso</option>
                                            <option value="5">Barras</option>
                                            <option value="7">Total</option>
                                            <option value="15">Ingredientes</option>
                                        </select>
                                        <button class="btn btn-outline-primary" @onclick="AgregarManual"><i class="bi bi-plus"></i></button>
                                    </div>
                                    <hr />
                                    <label class="small fw-bold">Diseño</label>
                                    <div class="row g-1">
                                        <div class="col">Width: <input type="number" class="form-control form-control-sm" @bind="selectedFormat.WidthLabel" /></div>
                                        <div class="col">Height: <input type="number" class="form-control form-control-sm" @bind="selectedFormat.HeightLabel" /></div>
                                    </div>
                                </div>
                                <div class="card-footer bg-white">
                                    <button class="btn btn-success w-100" @onclick="GuardarLocal"><i class="bi bi-save me-1"></i> Guardar Local</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-white">
                    <button class="btn btn-primary me-auto" @onclick="SyncCurrent"><i class="bi bi-cloud-upload"></i> Enviar a Balanza</button>
                    <button class="btn btn-secondary" @onclick="() => selectedFormat = null">Cerrar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<FileInfo> archivos = new();
    private List<Balanza> balanzas = new();
    private string SelectedBalanzaIp = "";
    private string? Mensaje;
    private LabelFormatInfo? selectedFormat;
    private LabelField? selectedField;
    private int newFieldId;

    protected override async Task OnInitializedAsync()
    {
        balanzas = await DbContext.Balanzas.ToListAsync();
        CargarArchivos();
    }

    private void CargarArchivos()
    {
        try {
            string path = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Digi");
            if (!Directory.Exists(path)) Directory.CreateDirectory(path);
            archivos = new DirectoryInfo(path).GetFiles("*F52.DAT").ToList();
        } catch { }
    }

    private async Task UploadFile(InputFileChangeEventArgs e)
    {
        if (string.IsNullOrEmpty(SelectedBalanzaIp)) return;
        try {
            string target = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "Digi", $"SM{SelectedBalanzaIp}F52.DAT");
            using var fs = new FileStream(target, FileMode.Create);
            await e.File.OpenReadStream().CopyToAsync(fs);
            CargarArchivos();
            Mensaje = "Archivo cargado.";
        } catch { }
    }

    private async Task Visualizar(string name)
    {
        selectedFormat = await DigiService.GetLabelFormatInfoAsync(name);
        selectedField = null;
    }

    private async Task GuardarLocal()
    {
        if (selectedFormat == null) return;
        await DigiService.SaveLabelFormatAsync(selectedFormat);
        Mensaje = "Guardado localmente.";
    }

    private async Task SyncCurrent()
    {
        if (selectedFormat == null) return;
        string ip = selectedFormat.FileName.Replace("SM", "").Replace("F52.DAT", "");
        await DigiService.SendEtiquetasAsync(ip);
        Mensaje = "Enviado a balanza.";
    }

    private async Task EnviarABalanza()
    {
        if (string.IsNullOrEmpty(SelectedBalanzaIp)) return;
        await DigiService.SendEtiquetasAsync(SelectedBalanzaIp);
        Mensaje = "Enviado a balanza.";
    }

    private void AgregarManual()
    {
        if (selectedFormat == null || newFieldId == 0) return;
        var field = new LabelField { 
            FieldId = newFieldId, 
            FieldName = DigiService.GetOriginalFieldName(newFieldId),
            X = 100, Y = 100, Font = 10 
        };
        selectedFormat.Fields.Add(field);
        selectedField = field;
    }

    private void Eliminar(string path)
    {
        try { File.Delete(path); CargarArchivos(); } catch { }
    }
}
