@page "/licencia"
@rendermode InteractiveServer
@using BalanzaQ.Web.Services
@inject LicenseService LicenseService
@inject NavigationManager NavigationManager

<PageTitle>BalanzaQ - Licencia Requerida</PageTitle>

<div class="container d-flex align-items-center justify-content-center" style="min-height: 85vh;">
    <div class="col-md-6 col-lg-5">
        <div class="card card-premium shadow-premium border-0 overflow-hidden anim-fade-in">
            <div class="card-header bg-dark text-white text-center py-5 position-relative border-0">
                <div class="position-absolute top-0 start-0 w-100 h-100 opacity-25" style="background: radial-gradient(circle at center, #3b82f6 0%, transparent 70%);"></div>
                <div class="icon-box-lg bg-danger-soft text-danger mx-auto mb-3 shadow-lg position-relative">
                    <i class="bi bi-shield-lock-fill fs-1"></i>
                </div>
                <h3 class="fw-bold mb-1 position-relative">Activación Requerida</h3>
                <p class="text-white-50 xsmall mb-0 position-relative">BalanzaQ Licensing Protocol v3.5</p>
            </div>
            <div class="card-body p-4 p-lg-5">
                <div class="text-center mb-4">
                    <p class="text-muted small px-3">
                        Este software está vinculado exclusivamente a este hardware. 
                        @if (File.Exists(Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "license.lic")))
                        {
                            <span class="text-danger fw-bold d-block mt-2">
                                <i class="bi bi-exclamation-octagon-fill me-1"></i> La licencia actual ha expirado o no es válida.
                            </span>
                        }
                        Por favor, proporcione el ID de su equipo para obtener una clave de activación válida.
                    </p>
                </div>

                <div class="bg-light rounded-4 p-4 mb-4 border border-opacity-10 shadow-inner text-center">
                    <label class="xsmall text-uppercase fw-bold text-muted d-block mb-3">Identificador de Hardware (UID)</label>
                    <div class="h5 font-monospace fw-bold text-dark text-break mb-0 bg-white py-3 px-2 rounded-3 border">
                        @LicenseService.GetMachineUID()
                    </div>
                    <button class="btn btn-link text-primary text-decoration-none xsmall fw-bold mt-2" @onclick="CopyUID">
                        <i class="bi bi-clipboard me-1"></i> COPIAR AL PORTAPAPELES
                    </button>
                </div>

                <div class="p-3 bg-primary-soft rounded-3 mb-4 d-flex align-items-start">
                    <i class="bi bi-info-circle-fill text-primary me-3 mt-1 fs-5"></i> 
                    <small class="text-primary xsmall">
                        Una vez reciba su archivo <strong>license.lic</strong>, cárguelo en el directorio raíz y reinicie para desbloquear todas las funciones.
                    </small>
                </div>
                
                <div class="d-grid gap-2 mt-4">
                    <button class="btn btn-primary btn-lg shadow-sm rounded-pill py-3 fw-bold" @onclick="CheckLicense">
                        <i class="bi bi-shield-check me-2"></i> RE-VALIDAR LICENCIA
                    </button>
                    <a href="https://wa.me/something" target="_blank" class="btn btn-outline-secondary btn-sm rounded-pill py-2 mt-2 border-0">
                        <i class="bi bi-headset me-2"></i> Contactar Soporte Técnico
                    </a>
                </div>
            </div>
            <div class="card-footer bg-light text-center py-3 xsmall text-muted border-0">
                &copy; 2026 Digi System Solutions
            </div>
        </div>
    </div>
</div>

@code {
    [Inject] private IJSRuntime JS { get; set; } = null!;

    private async Task CopyUID()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", LicenseService.GetMachineUID());
        await JS.InvokeVoidAsync("alert", "ID copiado al portapapeles.");
    }

    private void CheckLicense()
    {
        if (LicenseService.IsLicensed())
        {
            NavigationManager.NavigateTo("/", true);
        }
        else
        {
            // Forzar recarga física de la app para re-validar archivo en disco
            NavigationManager.NavigateTo("/licencia", true);
        }
    }

    protected override void OnInitialized()
    {
        // Si ya está licenciado, no debe estar aquí
        if (LicenseService.IsLicensed())
        {
            NavigationManager.NavigateTo("/");
        }
    }
}
