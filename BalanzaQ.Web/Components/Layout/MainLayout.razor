@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 shadow-sm" style="background: white; border-bottom: 1px solid #eee;">
            <div class="d-flex align-items-center w-100">
                <span class="text-muted small fw-medium">
                    <i class="bi bi-info-circle me-1"></i> Sistema de Gestión BalanzaQ
                </span>
                <span class="ms-auto badge bg-light text-primary border border-primary-subtle px-3 py-2 rounded-pill shadow-sm">
                    <i class="bi bi-patch-check-fill me-1"></i> @BalanzaQ.Web.Data.AppConstants.AppVersion
                </span>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
