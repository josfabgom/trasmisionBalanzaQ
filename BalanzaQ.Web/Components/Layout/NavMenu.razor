@using BalanzaQ.Web.Data
@using BalanzaQ.Web.Services
@inject IJSRuntime JSRuntime
@inject BrandingService BrandingService
@inject LicenseService LicenseService
@implements IDisposable
@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" href="">
            <span class="fw-bold" style="letter-spacing: 0.5px;">Balanza<span class="text-info">Q</span></span>
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link fs-6 btn-outline-primary rounded transition-all" href="" Match="NavLinkMatch.All">
                <i class="bi bi-speedometer2 me-3 fs-5" aria-hidden="true"></i> Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link fs-6 btn-outline-primary rounded transition-all" href="articulos">
                <i class="bi bi-tag-fill me-3 fs-5" aria-hidden="true"></i> Artículos (PLU)
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link fs-6 btn-outline-primary rounded transition-all" href="mantenimiento">
                <i class="bi bi-tools me-3 fs-5" aria-hidden="true"></i> Mantenimiento
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link fs-6 btn-outline-primary rounded transition-all" href="balanzas">
                <i class="bi bi-pc-display-horizontal me-3 fs-5" aria-hidden="true"></i> Balanzas Digi
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link fs-6 btn-outline-primary rounded transition-all" href="etiquetas">
                <i class="bi bi-layout-text-window-reverse me-3 fs-5" aria-hidden="true"></i> Formatos Etiqueta
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link fs-6 btn-outline-primary rounded transition-all" href="auditoria">
                <i class="bi bi-shield-check-fill me-3 fs-5" aria-hidden="true"></i> Auditoría Envío
            </NavLink>
        </div>

        @if (BrandingService.BusinessName != "BalanzaQ" || !string.IsNullOrEmpty(BrandingService.BusinessAddress))
        {
            <div class="nav-item px-3 mt-4 border-top pt-3 text-start small opacity-75">
                <div class="d-flex align-items-center mb-2">
                    @if (!string.IsNullOrEmpty(BrandingService.BusinessLogoBase64))
                    {
                        <img src="data:image/png;base64,@BrandingService.BusinessLogoBase64" alt="Logo" style="height: 40px; border-radius: 4px;" class="me-2 bg-white p-1" />
                    }
                    <div class="text-white fw-bold" style="font-size: 0.85rem;">@BrandingService.BusinessName</div>
                </div>
                @if (!string.IsNullOrEmpty(BrandingService.BusinessAddress))
                {
                    <div class="text-muted" style="font-size: 0.7rem;">
                        <i class="bi bi-geo-alt-fill me-1"></i> @BrandingService.BusinessAddress
                    </div>
                }
                @if (!string.IsNullOrEmpty(BrandingService.BusinessPhone))
                {
                    <div class="text-muted" style="font-size: 0.7rem;">
                        <i class="bi bi-telephone-fill me-1"></i> @BrandingService.BusinessPhone
                    </div>
                }
                @if (!string.IsNullOrEmpty(BrandingService.BusinessEmail))
                {
                    <div class="text-muted" style="font-size: 0.7rem;">
                        <i class="bi bi-envelope-fill me-1"></i> @BrandingService.BusinessEmail
                    </div>
                }
            </div>
        }

        @if (LicenseService.IsLicensed())
        {
            <div class="nav-item px-3 mt-2 text-start">
                <div class="text-success small d-flex flex-column" style="font-size: 0.7rem; line-height: 1.2;">
                    <span class="fw-bold"><i class="bi bi-patch-check-fill me-1"></i> Software Licenciado</span>
                    @if (LicenseService.ExpiryDate.HasValue)
                    {
                        <span class="text-muted">Vence: @LicenseService.ExpiryDate.Value.ToString("dd/MM/yyyy")</span>
                    }
                </div>
            </div>
        }

        <div class="nav-item px-3 mt-2 text-center border-top pt-2">
            <span class="text-muted small opacity-75" style="font-size: 0.75rem;">
                <i class="bi bi-info-circle me-1"></i> Versión @AppVersion
            </span>
        </div>

        <div class="nav-item px-3 mt-2">
            <button class="btn btn-link nav-link text-danger w-100 text-start" @onclick="CerrarSistema">
                <i class="bi bi-power me-3 fs-5"></i> Cerrar Sistema
            </button>
        </div>
    </nav>
</div>

@code {
    private string AppVersion => BalanzaQ.Web.Data.AppConstants.AppVersion;

    protected override void OnInitialized()
    {
        BrandingService.OnBrandingChanged += StateHasChanged;
    }

    public void Dispose()
    {
        BrandingService.OnBrandingChanged -= StateHasChanged;
    }

    private async Task CerrarSistema()
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "¿Está seguro que desea cerrar el sistema por completo?");
        if (!confirmed) return;

        try 
        {
            // Intentar cerrar la pestaña del navegador o limpiar la pantalla
            await JSRuntime.InvokeVoidAsync("eval", "window.close(); if(!window.closed){ window.location.href = 'about:blank'; }");
            
            // Esperar un momento para que el navegador procese el comando
            await Task.Delay(1000);

            // Limpiar procesos de driver si quedaron colgados
            var drivers = System.Diagnostics.Process.GetProcessesByName("digiwtcp");
            foreach (var d in drivers) try { d.Kill(); } catch { }
        }
        catch { }
        
        // Finalizar la aplicación por completo
        Environment.Exit(0);
    }
}
