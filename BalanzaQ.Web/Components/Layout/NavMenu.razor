@using BalanzaQ.Web.Data
@using BalanzaQ.Web.Services
@inject IJSRuntime JSRuntime
@inject BrandingService BrandingService
@inject LicenseService LicenseService
@implements IDisposable
@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" href="">
            <div class="bg-info-soft rounded-pill p-1 me-2" style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                 <i class="bi bi-cpu text-info"></i>
            </div>
            <span class="fw-bold h5 mb-0" style="letter-spacing: 1px;">Balanza<span class="text-info">Q</span></span>
        </a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column mt-3">
        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <i class="bi bi-grid-1x2 me-3 fs-5" aria-hidden="true"></i> Dashboard
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link" href="articulos">
                <i class="bi bi-box-seam me-3 fs-5" aria-hidden="true"></i> Artículos (PLU)
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link" href="balanzas">
                <i class="bi bi-pc-display-horizontal me-3 fs-5" aria-hidden="true"></i> Balanzas Digi
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link" href="etiquetas">
                <i class="bi bi-printer me-3 fs-5" aria-hidden="true"></i> Formatos Etiqueta
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link" href="auditoria">
                <i class="bi bi-clipboard-pulse me-3 fs-5" aria-hidden="true"></i> Auditoría Envío
            </NavLink>
        </div>

        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link" href="mantenimiento">
                <i class="bi bi-gear me-3 fs-5" aria-hidden="true"></i> Configuración
            </NavLink>
        </div>

        @* Sección de branding removida a petición del usuario *@

        @if (LicenseService.IsLicensed())
        {
            <div class="nav-item px-3 mt-2 mb-3">
                <div class="p-2 rounded-3 border border-success border-opacity-50 text-center anim-fade-in" style="background: rgba(25, 135, 84, 0.1);">
                    <div class="text-success fw-bold xsmall">
                        <i class="bi bi-patch-check-fill me-1"></i> LICENCIA ACTIVA
                    </div>
                    @if (LicenseService.ExpiryDate.HasValue)
                    {
                        <div class="text-white opacity-75 xsmall mt-1">Vto: @LicenseService.ExpiryDate.Value.ToString("dd/MM/yyyy")</div>
                    }
                </div>
            </div>
        }

        <div class="nav-item px-3 mt-auto mb-2 text-center border-top border-white border-opacity-10 pt-3">
            <span class="text-white-50 xsmall opacity-75">
                 v@(AppVersion)
            </span>
        </div>

        <div class="nav-item px-3 mb-3">
            <button class="btn btn-link nav-link text-danger w-100 text-start py-2" @onclick="CerrarSistema">
                <i class="bi bi-power me-3 fs-5"></i> Salir
            </button>
        </div>
    </nav>
</div>

@code {
    private string AppVersion => BalanzaQ.Web.Data.AppConstants.AppVersion;

    protected override void OnInitialized()
    {
        BrandingService.OnBrandingChanged += StateHasChanged;
    }

    public void Dispose()
    {
        BrandingService.OnBrandingChanged -= StateHasChanged;
    }

    private async Task CerrarSistema()
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "¿Está seguro que desea cerrar el sistema por completo?");
        if (!confirmed) return;

        try 
        {
            // Intentar cerrar la pestaña del navegador o limpiar la pantalla
            await JSRuntime.InvokeVoidAsync("eval", "window.close(); if(!window.closed){ window.location.href = 'about:blank'; }");
            
            // Esperar un momento para que el navegador procese el comando
            await Task.Delay(1000);

            // Limpiar procesos de driver si quedaron colgados
            var drivers = System.Diagnostics.Process.GetProcessesByName("digiwtcp");
            foreach (var d in drivers) try { d.Kill(); } catch { }
        }
        catch { }
        
        // Finalizar la aplicación por completo
        Environment.Exit(0);
    }
}
